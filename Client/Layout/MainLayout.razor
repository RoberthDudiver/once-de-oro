@inherits LayoutComponentBase
@implements IDisposable
@inject GameService Game
@inject Loc Loc
@inject AuthService Auth
@inject NavigationManager Nav

<div class="shell">
    <header class="topbar">
        <div class="topbar__crest">⚽</div>
        <div>
            <div class="topbar__club">@Game.State.ClubName</div>
            <div class="topbar__sub">@Loc["Once de Oro · Manager"]</div>
        </div>
        <div class="topbar__spacer"></div>
        <div class="lang" title="@(Loc["Idioma"])">
            @foreach (var l in Loc.Languages)
            {
                <button class="lang__btn @(Loc.Lang == l.Code ? "on" : "")"
                        title="@l.Name" @onclick="() => ChangeLang(l.Code)">@l.Flag</button>
            }
        </div>
        <div class="money" title="@Loc["Presupuesto disponible"]">
            <span class="money__cur">$</span>
            <span class="money__val">@Game.State.Money</span>
            <span class="money__unit">M</span>
        </div>
        @if (Auth.Available)
        {
            <a href="cuenta" class="acct" title="@(Auth.IsLoggedIn ? Auth.Email : Loc["Guardá tu progreso"])">
                @if (Auth.IsLoggedIn)
                {
                    <span class="acct__avatar">@((Auth.DisplayName.Length > 0 ? Auth.DisplayName[..1] : "?").ToUpperInvariant())</span>
                }
                else
                {
                    <span class="acct__cta">@Loc["Guardar progreso"]</span>
                }
            </a>
        }
    </header>

    <nav class="nav">
        <a href="" class="@Active("")"><span class="ico">🏠</span>@Loc["Inicio"]</a>
        <a href="mercado" class="@Active("mercado")"><span class="ico">💰</span>@Loc["Mercado"]</a>
        <a href="equipo" class="@Active("equipo")"><span class="ico">👕</span>@Loc["Equipo"]</a>
        <a href="torneos" class="@Active("torneos")"><span class="ico">🏆</span>@Loc["Torneos"]</a>
        <a href="online" class="@Active("online")"><span class="ico">🌐</span>@Loc["Online"]</a>
    </nav>

    @Body
</div>

@code {
    protected override async Task OnInitializedAsync()
    {
        Game.Changed += OnChanged;
        Loc.Changed += OnChanged;
        Auth.Changed += OnChanged;
        Nav.LocationChanged += OnLocation;
        await Loc.LoadAsync();
        await Game.LoadAsync();
        await Auth.InitAsync();

        // Si la sesión seguía abierta, traemos/conciliamos la partida de la cuenta.
        if (Auth.IsLoggedIn) await Game.SyncAfterAuthAsync(justRegistered: false);
    }

    private async Task ChangeLang(string code) => await Loc.SetLangAsync(code);

    private void OnChanged() => InvokeAsync(StateHasChanged);
    private void OnLocation(object? _, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs __) => InvokeAsync(StateHasChanged);

    private string Active(string path)
    {
        var rel = Nav.ToBaseRelativePath(Nav.Uri).TrimEnd('/');
        rel = rel.Split('?')[0];
        return rel == path ? "active" : "";
    }

    public void Dispose()
    {
        Game.Changed -= OnChanged;
        Loc.Changed -= OnChanged;
        Auth.Changed -= OnChanged;
        Nav.LocationChanged -= OnLocation;
    }
}
