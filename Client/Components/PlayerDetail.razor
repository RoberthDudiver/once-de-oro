@* Ficha completa del jugador: quién es, cómo está y qué hizo con vos *@
@using OnceDeOro.Models
@using OnceDeOro.Data
@inject GameService Game
@inject Loc Loc

@if (P is not null)
{
    // Si es tuyo se lee SIEMPRE del estado vivo y no del parámetro: al fusionar
    // cambia la fuerza, y el padre vuelve a pasarnos la carta vieja en el próximo
    // render, así que quedarse con P dejaba la ficha mostrando el número anterior.
    var p = Game.Owned.FirstOrDefault(x => x.Id == P.Id) ?? P;
    var c = Game.Cond(p.Id);
    var fat = c.Fatigue;
    var pen = GameService.FatiguePenalty(fat);
    var aca = Game.State.Academy.FirstOrDefault(a => a.Id == p.Id);
    var esMio = Game.State.OwnedIds.Contains(p.Id);
    // Si alguna vez jugó para vos, el historial sigue teniendo sentido aunque lo hayas vendido.
    var tieneHistorial = c.Matches > 0;

    <div class="modal" @onclick="Close">
        <div class="modal__box" @onclick:stopPropagation="true">
            <button class="modal__x" @onclick="Close">✕</button>

            <div class="row" style="gap:14px; align-items:flex-start;">
                <div class="dot-player @Tier(p.Rating)" style="width:64px;height:64px;font-size:26px;">@p.Rating</div>
                <div style="min-width:0;">
                    <div style="font-family:var(--font-head); font-size:22px; line-height:1.1;">
                        @p.Name @if (p.IsLegend) { <span class="star">★</span> }
                    </div>
                    <div class="muted" style="font-size:13px; margin-top:3px;">
                        @p.Pos.Full() · @p.Nation · @Loc["Época"] @p.Era
                    </div>
                    <div class="row wrap" style="gap:6px; margin-top:8px;">
                        <span class="pill pill--gold">💰 $@p.Value M</span>
                        @if (aca is not null)
                        {
                            <span class="pill">🎓 @Loc[GameService.AcademyTier(aca.Rating)]</span>
                        }
                    </div>
                </div>
            </div>

            @* ---------- Carrera REAL (sólo si tenemos datos verificados) ---------- *@
            @{ var real = RealData.Player(p.Name); }
            @if (real is not null)
            {
                <div class="section-title" style="margin:20px 0 12px;"><span class="dot"></span> @Loc["Carrera real"]</div>
                <div class="stat-grid">
                    @if (real.Caps > 0)
                    {
                        <div class="stat-cell"><b>@real.Caps</b><span>@Loc["Partidos con su selección"]</span></div>
                    }
                    @if (real.IntGoals > 0)
                    {
                        <div class="stat-cell"><b>@real.IntGoals</b><span>@Loc["Goles con su selección"]</span></div>
                    }
                    @if (real.WorldCups.Length > 0)
                    {
                        <div class="stat-cell"><b>@real.WorldCups.Length</b><span>🏆 @Loc["Mundiales"]</span></div>
                    }
                    @if (real.BallonDor > 0)
                    {
                        <div class="stat-cell"><b>@real.BallonDor</b><span>🥇 @Loc["Balón de Oro"]</span></div>
                    }
                    @if (real.EuropeanCups > 0)
                    {
                        <div class="stat-cell"><b>@real.EuropeanCups</b><span>⭐ @Loc["Copas de Europa"]</span></div>
                    }
                </div>
                @if (real.WorldCups.Length > 0)
                {
                    <div class="muted mt" style="font-size:12.5px;">
                        🏆 @Loc["Campeón del Mundo en"] @string.Join(", ", real.WorldCups)
                    </div>
                }
                @if (!string.IsNullOrEmpty(real.Note))
                {
                    <div class="real-note">“@real.Note”</div>
                }
            }

            @* ---------- Su selección ---------- *@
            @{ var pais = RealData.Country(p.Nation); }
            @if (pais is not null)
            {
                <div class="section-title" style="margin:20px 0 12px;"><span class="dot"></span> @p.Flag @p.Nation</div>
                <div class="row wrap" style="gap:6px;">
                    <span class="pill">@pais.Confed</span>
                    @if (pais.WorldCups.Length > 0)
                    {
                        <span class="pill pill--gold">🏆 @pais.WorldCups.Length @Loc["Mundiales"]</span>
                    }
                    @if (pais.WorldCupRunnerUp > 0)
                    {
                        <span class="pill">🥈 @pais.WorldCupRunnerUp @Loc["finales perdidas"]</span>
                    }
                    @if (pais.Continental > 0)
                    {
                        <span class="pill pill--green">@pais.Continental @pais.ContinentalName</span>
                    }
                </div>
                @if (pais.WorldCups.Length > 0)
                {
                    <div class="muted mt" style="font-size:12.5px;">@string.Join(" · ", pais.WorldCups)</div>
                }
                @if (!string.IsNullOrEmpty(pais.Note))
                {
                    <div class="real-note">“@pais.Note”</div>
                }
            }

            @* ---------- Atributos propios del jugador ---------- *@
            <div class="section-title" style="margin:20px 0 12px;"><span class="dot"></span> @Loc["Atributos"]</div>
            <div class="faint" style="font-size:11.5px; margin-bottom:8px;">@Loc["Cualidades dentro del juego, derivadas de su fuerza."]</div>
            <div class="attrs">
                @foreach (var (etiqueta, valor) in Attributes(p))
                {
                    <div class="attr">
                        <span class="attr__lbl">@Loc[etiqueta]</span>
                        @* La barra se llena hasta el borde; el número sí muestra el valor real. *@
                        <div class="attr__bar"><span class="@BarClass(valor)" style="width:@(Math.Min(100, valor))%"></span></div>
                        <span class="attr__num">@valor</span>
                    </div>
                }
            </div>

            @* ---------- Fusión: la versión común mejora al prime ---------- *@
            @if (esMio && PrimeDatabase.IsPrimeName(p.Name) && p.Rating < GameService.PrimeMax)
            {
                var fuente = Game.FuseSource(p);
                <div class="fuse">
                    @if (fuente is not null)
                    {
                        <div class="fuse__txt">
                            ⬆️ @Loc["Podés sacrificar a"] <b>@fuente.Name (@fuente.Rating)</b>
                            @Loc["para que este suba a"] <b>@(p.Rating + 1)</b>.
                        </div>
                        <button class="btn btn--gold" @onclick="() => Fusionar(p.Id)">
                            @Loc["Mejorar"] · @(p.Rating) → @(p.Rating + 1)
                        </button>
                    }
                    else if (Game.IsFused(p.Id))
                    {
                        <div class="fuse__txt faint">
                            ✓ @Loc["Ya lo mejoraste. Se puede una sola vez por jugador."]
                        </div>
                    }
                    else
                    {
                        <div class="fuse__txt faint">
                            @Loc["Conseguí a"] <b>@PrimeDatabase.BaseName(p.Name)</b>
                            @Loc["en el mercado y lo podés sacrificar para subirle un punto a este."]
                        </div>
                    }
                </div>
            }

            @if (p.Troll)
            {
                <div class="real-note" style="border-color:rgba(255,120,180,.5);">
                    🤡 @Loc["Cotiza 110 y remata como nadie, pero adentro de la cancha rinde como un 45. Te vendieron humo."]
                </div>
            }

            @* ---------- Lo de abajo solo aplica a jugadores TUYOS ---------- *@
            @if (!esMio && !tieneHistorial)
            {
                <div class="muted mt" style="font-size:12.5px; text-align:center;">
                    @Loc["No está en tu equipo. Fichalo para verlo rendir y llevarle las estadísticas."]
                </div>
            }

            @if (esMio)
            {
            <div class="section-title" style="margin:20px 0 12px;"><span class="dot"></span> @Loc["Estado físico"]</div>

            @if (c.Injured)
            {
                <div class="pill" style="width:100%; justify-content:center; padding:10px; color:var(--red); border-color:rgba(255,90,106,.45);">
                    🚑 @Loc["Lesionado"] · @c.OutMatches @(c.OutMatches == 1 ? Loc["partido"] : Loc["partidos"])
                </div>
            }
            else if (c.Suspended > 0)
            {
                <div class="pill" style="width:100%; justify-content:center; padding:10px; color:var(--red); border-color:rgba(255,90,106,.45);">
                    🟥 @Loc["Suspendido"] · @c.Suspended @(c.Suspended == 1 ? Loc["partido"] : Loc["partidos"])
                </div>
            }
            else
            {
                <div class="pill pill--green" style="width:100%; justify-content:center; padding:10px;">
                    ✓ @Loc["Disponible"]
                </div>
            }

            <div class="fat mt">
                <div class="row" style="justify-content:space-between; font-size:12.5px;">
                    <span class="muted">@Loc["Cansancio"]</span>
                    <span style="color:@(fat >= 70 ? "var(--red)" : fat >= 40 ? "var(--gold-2)" : "var(--green)")">
                        @fat%@(pen > 0 ? $" · −{pen} " + Loc["de fuerza"] : "")
                    </span>
                </div>
                <div class="fat__bar"><span class="@(fat >= 70 ? "hot" : fat >= 40 ? "warm" : "")" style="width:@(fat)%"></span></div>
                <div class="faint" style="font-size:11.5px; margin-top:5px;">
                    @Loc["Descansa cuando no juega. Jugar fundido aumenta el riesgo de lesión."]
                </div>
            </div>
            }

            @* ---------- Estadísticas con vos (solo si jugó o es tuyo) ---------- *@
            @if (esMio || tieneHistorial)
            {
            <div class="section-title" style="margin:20px 0 12px;"><span class="dot"></span> @Loc["Con tu equipo"]</div>
            <div class="stat-grid">
                <div class="stat-cell"><b>@c.Matches</b><span>@Loc["Partidos"]</span></div>
                <div class="stat-cell"><b>@c.Goals</b><span>@Loc["Goles"]</span></div>
                <div class="stat-cell"><b>@c.Yellow</b><span>🟨</span></div>
                <div class="stat-cell"><b>@c.Red</b><span>🟥</span></div>
                <div class="stat-cell"><b>@c.Injuries</b><span>🚑 @Loc["Lesiones"]</span></div>
                <div class="stat-cell"><b>@Ratio(c)</b><span>@Loc["Goles/partido"]</span></div>
            </div>
            }

            @if (aca is not null)
            {
                var need = GameService.XpNeeded(aca.Rating);
                <div class="section-title" style="margin:20px 0 12px;"><span class="dot"></span> @Loc["Academia"]</div>
                <div class="stat-grid">
                    <div class="stat-cell"><b>@aca.Sessions</b><span>@Loc["entrenos"]</span></div>
                    <div class="stat-cell"><b>@aca.Xp/@need</b><span>XP</span></div>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public Player? P { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private Task Close() => OnClose.InvokeAsync();

    /// <summary>
    /// Fusiona y refresca la ficha: el prime que se está mostrando cambió de fuerza,
    /// así que hay que volver a leerlo o la pantalla sigue mostrando el número viejo.
    /// </summary>
    private void Fusionar(string primeId) => Game.Fuse(primeId);

    private static string Tier(int r) => r >= 85 ? "" : r >= 75 ? "silver" : "bronze";

    private static string Ratio(PlayerCondition c) =>
        c.Matches == 0 ? "—" : (c.Goals / (double)c.Matches).ToString("0.00");

    private static string BarClass(int v) => v >= 85 ? "top" : v >= 70 ? "mid" : "low";

    /// <summary>Atributos por puesto. Cada jugador tiene su perfil propio.</summary>
    private static readonly Dictionary<Position, string[]> Skills = new()
    {
        [Position.GK]  = new[] { "Reflejos", "Achique", "Manos", "Juego aéreo", "Distribución" },
        [Position.DEF] = new[] { "Marca", "Quite", "Juego aéreo", "Fuerza", "Salida" },
        [Position.MID] = new[] { "Pase", "Visión", "Regate", "Resistencia", "Recuperación" },
        [Position.FWD] = new[] { "Definición", "Velocidad", "Regate", "Remate", "Desmarque" },
    };

    /// <summary>
    /// Perfil del jugador derivado de su fuerza y su puesto. Es ESTABLE: depende
    /// de su Id, así que siempre muestra lo mismo. No son datos reales de su
    /// carrera (no los tenemos), sino sus cualidades dentro del juego.
    /// </summary>
    private static List<(string, int)> Attributes(Player p)
    {
        var nombres = Skills[p.Pos];
        var result = new List<(string, int)>();

        // El payaso: lo que tiene que ver con atacar, al mango; todo lo demás, por
        // el piso. Por eso la carta dice 110 y el equipo igual juega peor con él.
        if (p.Troll)
        {
            var ataque = new[] { "Definición", "Remate", "Velocidad" };
            foreach (var n in nombres)
                result.Add((n, ataque.Contains(n) ? 99 : 31));
            return result;
        }

        // Los de 100 para arriba están fuera de escala: TODOS sus atributos valen
        // lo que valen ellos. Si les aplicáramos el techo de 99 como al resto, un
        // 105 se vería igual que un 99 y no se notaría en ningún lado que es mejor.
        if (p.Rating >= 100)
        {
            foreach (var n in nombres) result.Add((n, p.Rating));
            return result;
        }

        for (int i = 0; i < nombres.Length; i++)
        {
            // Variación determinística por jugador y atributo (-5 a +5)
            int h = Hash(p.Id + "|" + nombres[i]);
            int delta = (h % 11) - 5;
            // El primer atributo es el fuerte del puesto
            if (i == 0) delta += 3;
            result.Add((nombres[i], Math.Clamp(p.Rating + delta, 30, 99)));
        }
        return result;
    }

    private static int Hash(string s)
    {
        unchecked
        {
            int h = 17;
            foreach (char ch in s) h = h * 31 + ch;
            return Math.Abs(h);
        }
    }
}
