@* Avatar 2D estilo caricatura simple y amigable (nada realista, para no caer en el
   "valle inquietante"). Colores planos, ojitos redondos con brillo, sonrisa clara.
   Cada rasgo se posiciona/escala con los valores de ajuste fino (modo estiramiento). *@
@using OnceDeOro.Models

<svg class="avatar" viewBox="0 0 100 @(Body ? 132 : 100)" width="@Size" height="@(Body ? Size * 1.32 : Size)"
     role="img" aria-label="@(string.IsNullOrEmpty(A.Name) ? "Avatar" : A.Name)">
    <defs>
        @if (A.Beard)
        {
            <clipPath id="@_clip"><path d="@FacePath(A.Face)" /></clipPath>
        }
        @if (Body)
        {
            <linearGradient id="@_gJersey" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="@Shade(Primary, 14)" />
                <stop offset="1" stop-color="@Shade(Primary, -16)" />
            </linearGradient>
        }
    </defs>

    @* ---------- Cuerpo (torso con la camiseta del club) ---------- *@
    @if (Body)
    {
        <ellipse cx="50" cy="130" rx="28" ry="4.5" fill="rgba(0,0,0,.14)" />
        <g>
            @* cuello *@
            <rect x="43" y="83" width="14" height="13" rx="5" fill="@A.Skin" />
            @* camiseta *@
            <path d="M 27 101 Q 29 94 39 93 L 44 92 Q 50 99 56 92 L 61 93 Q 71 94 73 101 L 79 109 L 71 116 L 71 132 L 29 132 L 29 116 L 21 109 Z"
                  fill="url(#@_gJersey)" />
            @* mangas del color secundario *@
            <path d="M 27 101 L 21 109 L 28 115 L 34 104 Z" fill="@Secondary" />
            <path d="M 73 101 L 79 109 L 72 115 L 66 104 Z" fill="@Secondary" />
            @* cuello redondo del color secundario *@
            <path d="M 44 92 Q 50 99 56 92 L 53 96 Q 50 100 47 96 Z" fill="@Secondary" />
            <path d="M 42 93 Q 50 90 58 93 L 56 91 Q 50 88.5 44 91 Z" fill="@Secondary" />
        </g>
    }

    @* ---------- Cabeza, escalada en ancho por FaceW ---------- *@
    <g transform="translate(50,0) scale(@F(A.FaceW / 100.0),1) translate(-50,0)">
        @* pelo de atrás (nuca) *@
        @((MarkupString)HairBack(A.Hair, A.HairColor, A.HairY))

        @* orejas *@
        <circle cx="17" cy="53" r="6" fill="@A.Skin" stroke="rgba(0,0,0,.08)" stroke-width="1" />
        <circle cx="83" cy="53" r="6" fill="@A.Skin" stroke="rgba(0,0,0,.08)" stroke-width="1" />

        @* cara (color plano) *@
        <path d="@FacePath(A.Face)" fill="@A.Skin" stroke="rgba(0,0,0,.09)" stroke-width="1" />

        @* mejillas *@
        <circle cx="@F(50 - A.EyeSpread - 7)" cy="@F(A.EyeY + 12)" r="4.5" fill="#ff8f8f" opacity=".22" />
        <circle cx="@F(50 + A.EyeSpread + 7)" cy="@F(A.EyeY + 12)" r="4.5" fill="#ff8f8f" opacity=".22" />

        @if (A.Beard)
        {
            <path d="M @F(50 - A.EyeSpread - 12) @F(A.MouthY - 6) Q 50 @F(A.MouthY + 20) @F(50 + A.EyeSpread + 12) @F(A.MouthY - 6) L @F(50 + A.EyeSpread + 12) 84 Q 50 92 @F(50 - A.EyeSpread - 12) 84 Z"
                  fill="@A.HairColor" opacity=".9" clip-path="url(#@_clip)" />
        }

        @* ---- Cejas ---- *@
        <g transform="translate(@F(50 - A.EyeSpread),@A.BrowY)">@((MarkupString)Brow(A.Brows, false, A.HairColor))</g>
        <g transform="translate(@F(50 + A.EyeSpread),@A.BrowY)">@((MarkupString)Brow(A.Brows, true, A.HairColor))</g>

        @* ---- Ojos (redondos, con brillo — nada realista) ---- *@
        <g transform="translate(@F(50 - A.EyeSpread),@A.EyeY) scale(@F(A.EyeSize / 100.0))">@((MarkupString)Eye(A.Eyes, A.EyeColor, false))</g>
        <g transform="translate(@F(50 + A.EyeSpread),@A.EyeY) scale(@F(A.EyeSize / 100.0))">@((MarkupString)Eye(A.Eyes, A.EyeColor, true))</g>

        @* ---- Nariz (mínima) ---- *@
        <g transform="translate(50,@A.NoseY)">@((MarkupString)Nose(A.Nose, A.Skin))</g>

        @* ---- Boca ---- *@
        <g transform="translate(50,@A.MouthY) scale(@F(A.MouthSize / 100.0))">@((MarkupString)Mouth(A.Mouth))</g>

        @if (A.Glasses)
        {
            <g fill="rgba(180,210,235,.14)" stroke="@A.GlassesColor" stroke-width="2.2"
               transform="translate(0,@(A.EyeY - 50))">
                <rect x="@F(50 - A.EyeSpread - 8)" y="43" width="16" height="13" rx="6" />
                <rect x="@F(50 + A.EyeSpread - 8)" y="43" width="16" height="13" rx="6" />
                <line x1="@F(50 - A.EyeSpread + 8)" y1="48" x2="@F(50 + A.EyeSpread - 8)" y2="48" stroke-width="2.2" />
            </g>
        }

        @* pelo de adelante *@
        @((MarkupString)HairFront(A.Hair, A.HairColor, A.HairY))
    </g>
</svg>

@code {
    [Parameter, EditorRequired] public Avatar A { get; set; } = new();
    [Parameter] public int Size { get; set; } = 120;
    /// <summary>Si true, dibuja también el torso con la camiseta.</summary>
    [Parameter] public bool Body { get; set; }
    [Parameter] public string Primary { get; set; } = "#e23b3b";
    [Parameter] public string Secondary { get; set; } = "#ffffff";

    private readonly string _uid = "a" + Guid.NewGuid().ToString("N")[..6];
    private string _clip => _uid + "c";
    private string _gJersey => _uid + "j";

    public const int Faces = 5, Hairs = 8, EyesN = 6, BrowsN = 4, NosesN = 3, MouthsN = 6;

    private static string F(double v) => v.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);

    private static string FacePath(int f) => f switch
    {
        // ovalada suave
        0 => "M 50 14 C 70 14 79 31 79 51 C 79 72 67 88 50 88 C 33 88 21 72 21 51 C 21 31 30 14 50 14 Z",
        // redonda (cachetona)
        1 => "M 50 16 C 72 16 82 34 82 54 C 82 73 68 88 50 88 C 32 88 18 73 18 54 C 18 34 28 16 50 16 Z",
        // redondeada con mentón suave
        2 => "M 28 30 Q 28 18 42 17 Q 50 16 58 17 Q 72 18 72 30 L 78 52 Q 78 74 50 88 Q 22 74 22 52 Z",
        // corazón (mentón un poco más fino)
        3 => "M 50 16 C 72 16 81 32 78 51 C 75 72 61 88 50 88 C 39 88 25 72 22 51 C 19 32 28 16 50 16 Z",
        // alargada suave
        _ => "M 50 12 C 69 12 78 31 78 55 C 78 76 66 89 50 89 C 34 89 22 76 22 55 C 22 31 31 12 50 12 Z",
    };

    private static string HairBack(int h, string c, int dy)
    {
        string d = h switch
        {
            1 => "M 15 46 Q 14 92 32 92 L 68 92 Q 86 92 85 46 Q 80 64 50 64 Q 20 64 15 46 Z",
            4 => "M 13 44 Q 11 98 34 98 L 66 98 Q 89 98 87 44 Q 80 66 50 66 Q 20 66 13 44 Z",
            6 => "M 50 6 C 76 6 88 28 88 48 C 88 59 83 64 77 64 L 23 64 C 17 64 12 59 12 48 C 12 28 24 6 50 6 Z",
            7 => "M 16 48 Q 15 88 30 94 L 34 76 Q 50 82 66 76 L 70 94 Q 85 88 84 48 Z",
            _ => "",
        };
        return string.IsNullOrEmpty(d) ? "" : $"<path transform='translate(0,{dy})' d='{d}' fill='{c}'/>";
    }

    private static string HairFront(int h, string c, int dy)
    {
        string body = h switch
        {
            0 => "M 19 49 C 19 24 34 13 50 13 C 66 13 81 24 81 49 C 75 36 69 32 61 33 C 55 25 45 25 39 33 C 31 32 25 36 19 49 Z",
            1 => "M 17 53 C 15 26 34 14 50 14 C 66 14 85 26 83 53 C 78 38 71 34 63 35 C 57 26 43 26 37 35 C 29 34 22 38 17 53 Z",
            2 => "M 21 43 C 24 25 37 17 50 17 C 63 17 76 25 79 43 C 73 33 63 30 50 30 C 37 30 27 33 21 43 Z",
            3 => "M 19 49 C 19 22 35 13 50 13 C 65 13 81 22 81 49 C 76 37 69 33 61 35 L 56 24 L 50 35 L 44 24 L 39 35 C 31 33 24 37 19 49 Z",
            4 => "M 15 55 C 13 24 34 14 50 14 C 66 14 87 24 85 55 C 80 39 72 35 64 36 C 58 26 42 26 36 36 C 28 35 20 39 15 55 Z",
            5 => "M 23 40 C 27 25 38 18 50 18 C 62 18 73 25 77 40 C 68 35 60 46 50 42 C 40 46 32 35 23 40 Z",
            6 => "M 17 47 C 17 20 35 12 50 12 C 65 12 83 20 83 47 C 77 34 66 32 50 32 C 34 32 23 34 17 47 Z",
            7 => "M 18 51 C 16 26 34 15 50 15 C 66 15 84 26 82 51 C 76 34 70 46 59 41 C 53 32 43 45 35 41 C 27 45 23 36 18 51 Z",
            _ => "",
        };
        if (string.IsNullOrEmpty(body)) return "";
        // un brillo suave del mismo pelo, más claro
        string shine = $"<path d='M 31 22 Q 43 15 55 19' fill='none' stroke='{Shade(c, 34)}' stroke-width='3' stroke-linecap='round' opacity='.4'/>";
        return $"<g transform='translate(0,{dy})'><path d='{body}' fill='{c}'/>{shine}</g>";
    }

    // ---- Un ojo. Redondo y sólido con un brillo: tierno, nunca "realista". ----
    private static string Eye(int e, string c, bool derecho)
    {
        int s = derecho ? -1 : 1;
        const string dark = "#2b2622";
        string shine = "<circle cx='-1.3' cy='-1.6' r='1.1' fill='#fff'/>";
        return e switch
        {
            // redondo normal
            0 => $"<circle cx='0' cy='0' r='3.7' fill='{dark}'/>{shine}",
            // grande (ojazos)
            1 => $"<circle cx='0' cy='0' r='4.6' fill='{dark}'/><circle cx='-1.6' cy='-2' r='1.4' fill='#fff'/>",
            // feliz (arquito hacia arriba, ojo cerrado)
            2 => $"<path d='M {-4.5 * s} 1.5 Q 0 -3.5 {4.5 * s} 1.5' fill='none' stroke='{dark}' stroke-width='2.4' stroke-linecap='round'/>",
            // ovalado vertical
            3 => $"<ellipse cx='0' cy='0' rx='3' ry='4.2' fill='{dark}'/><circle cx='-1' cy='-1.6' r='1' fill='#fff'/>",
            // guiño / dormido (arquito hacia abajo)
            4 => $"<path d='M {-4.5 * s} -1 Q 0 3.5 {4.5 * s} -1' fill='none' stroke='{dark}' stroke-width='2.4' stroke-linecap='round'/>",
            // pequeño
            _ => $"<circle cx='0' cy='0' r='2.8' fill='{dark}'/><circle cx='-1' cy='-1.2' r='.9' fill='#fff'/>",
        };
    }

    private static string Brow(int b, bool derecho, string c)
    {
        int s = derecho ? -1 : 1;
        string col = Shade(c, -18);
        return b switch
        {
            0 => $"<path d='M {-5 * s} 0.5 Q 0 -2 {5 * s} 0.5' fill='none' stroke='{col}' stroke-width='2' stroke-linecap='round' opacity='.85'/>",
            1 => $"<path d='M {-5 * s} 0 L {5 * s} 0' stroke='{col}' stroke-width='2.2' stroke-linecap='round' opacity='.85'/>",
            2 => $"<path d='M {-5 * s} 1.5 Q 0 -1.5 {5 * s} 0' fill='none' stroke='{col}' stroke-width='2.2' stroke-linecap='round' opacity='.85'/>",
            _ => $"<path d='M {-5 * s} 0 Q 0 2.5 {5 * s} 0' fill='none' stroke='{col}' stroke-width='2' stroke-linecap='round' opacity='.85'/>",
        };
    }

    // nariz mínima, apenas insinuada
    private static string Nose(int n, string skin) => n switch
    {
        0 => $"<circle cx='0' cy='1' r='1.6' fill='{Shade(skin, -22)}' opacity='.5'/>",
        1 => $"<path d='M 0 -3 L 0 2.5' stroke='{Shade(skin, -24)}' stroke-width='1.6' stroke-linecap='round' opacity='.5'/>",
        _ => $"<path d='M -2 0 Q 0 2.5 2 0' fill='none' stroke='{Shade(skin, -24)}' stroke-width='1.6' stroke-linecap='round' opacity='.5'/>",
    };

    // bocas simples y amables
    private static string Mouth(int m) => m switch
    {
        // sonrisa
        0 => "<path d='M -8 -1 Q 0 5 8 -1' fill='none' stroke='#c05a4e' stroke-width='2.4' stroke-linecap='round'/>",
        // neutra
        1 => "<path d='M -6 0 L 6 0' stroke='#c05a4e' stroke-width='2.4' stroke-linecap='round'/>",
        // sonrisa grande (rellena, sin dientes, tierna)
        2 => "<path d='M -8 -1 Q 0 8 8 -1 Q 0 3 -8 -1 Z' fill='#c05a4e'/>",
        // pícara (media sonrisa)
        3 => "<path d='M -7 0 Q 0 4 8 -2' fill='none' stroke='#c05a4e' stroke-width='2.4' stroke-linecap='round'/>",
        // boquita 'o'
        4 => "<circle cx='0' cy='1' r='3' fill='#c05a4e'/>",
        // seria
        _ => "<path d='M -7 1.5 Q 0 -1.5 7 1.5' fill='none' stroke='#c05a4e' stroke-width='2.4' stroke-linecap='round'/>",
    };

    private static string Shade(string hex, int d)
    {
        if (hex.Length != 7) return hex;
        int C(int i) => Math.Clamp(Convert.ToInt32(hex.Substring(i, 2), 16) + d, 0, 255);
        return $"#{C(1):x2}{C(3):x2}{C(5):x2}";
    }
}
