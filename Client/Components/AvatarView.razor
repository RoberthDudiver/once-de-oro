@* Avatar 2D estilizado (tipo Mii plano, con sombreado suave) dibujado por código en SVG.
   Cada rasgo se posiciona y escala con los valores de ajuste fino, así se puede "estirar". *@
@using OnceDeOro.Models

<svg class="avatar" viewBox="0 0 100 @(Body ? 132 : 100)" width="@Size" height="@(Body ? Size * 1.32 : Size)"
     role="img" aria-label="@(string.IsNullOrEmpty(A.Name) ? "Avatar" : A.Name)">
    <defs>
        <clipPath id="@_clip"><path d="@FacePath(A.Face)" /></clipPath>

        @* piel: luz arriba, sombra abajo *@
        <linearGradient id="@_gSkin" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0" stop-color="@Shade(A.Skin, 16)" />
            <stop offset="0.5" stop-color="@A.Skin" />
            <stop offset="1" stop-color="@Shade(A.Skin, -18)" />
        </linearGradient>
        @* pelo: brillo diagonal *@
        <linearGradient id="@_gHair" x1="0.2" y1="0" x2="0.8" y2="1">
            <stop offset="0" stop-color="@Shade(A.HairColor, 30)" />
            <stop offset="0.45" stop-color="@A.HairColor" />
            <stop offset="1" stop-color="@Shade(A.HairColor, -24)" />
        </linearGradient>
        @if (Body)
        {
            <linearGradient id="@_gJersey" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0" stop-color="@Shade(Primary, 20)" />
                <stop offset="1" stop-color="@Shade(Primary, -22)" />
            </linearGradient>
        }
    </defs>

    @* ---------- Cuerpo (torso con la camiseta del club) ---------- *@
    @if (Body)
    {
        <ellipse cx="50" cy="129" rx="30" ry="5" fill="rgba(0,0,0,.16)" />
        <g>
            @* cuello con su sombra *@
            <rect x="43" y="82" width="14" height="14" rx="5" fill="@A.Skin" />
            <path d="M 43 90 Q 50 96 57 90 L 57 96 L 43 96 Z" fill="@Shade(A.Skin, -22)" opacity=".55" />
            @* camiseta *@
            <path d="M 27 100 Q 29 93 38 92 L 43 91 Q 50 99 57 91 L 62 92 Q 71 93 73 100 L 79 108 L 71 115 L 71 132 L 29 132 L 29 115 L 21 108 Z"
                  fill="url(#@_gJersey)" />
            @* sombra lateral del torso, para dar volumen *@
            <path d="M 29 115 L 29 132 L 36 132 L 35 116 Z" fill="rgba(0,0,0,.12)" />
            <path d="M 71 115 L 71 132 L 64 132 L 65 116 Z" fill="rgba(255,255,255,.10)" />
            @* mangas con el color secundario *@
            <path d="M 27 100 L 21 108 L 28 114 L 34 103 Z" fill="@Secondary" />
            <path d="M 73 100 L 79 108 L 72 114 L 66 103 Z" fill="@Secondary" />
            <path d="M 26 111 L 30 108 L 33 112 L 29 116 Z" fill="@Shade(Secondary, -18)" />
            <path d="M 74 111 L 70 108 L 67 112 L 71 116 Z" fill="@Shade(Secondary, -18)" />
            @* cuello en V del color secundario *@
            <path d="M 43 91 Q 50 99 57 91 L 54 95 Q 50 101 46 95 Z" fill="@Secondary" />
            <path d="M 41 92 Q 50 90 59 92 L 57 90 Q 50 88 43 90 Z" fill="@Secondary" />
        </g>
    }

    @* ---------- Cabeza, escalada en ancho por FaceW ---------- *@
    <g transform="translate(50,0) scale(@F(A.FaceW / 100.0),1) translate(-50,0)">
        @* pelo de atrás (nuca) *@
        @((MarkupString)HairBack(A.Hair, A.HairY, _gHair))

        @* orejas *@
        <ellipse cx="16" cy="53" rx="6.5" ry="8" fill="@A.Skin" stroke="rgba(0,0,0,.10)" stroke-width="1" />
        <ellipse cx="84" cy="53" rx="6.5" ry="8" fill="@A.Skin" stroke="rgba(0,0,0,.10)" stroke-width="1" />
        <path d="M 14 49 Q 18 53 15 58" fill="none" stroke="@Shade(A.Skin, -30)" stroke-width="1.4" stroke-linecap="round" opacity=".6" />
        <path d="M 86 49 Q 82 53 85 58" fill="none" stroke="@Shade(A.Skin, -30)" stroke-width="1.4" stroke-linecap="round" opacity=".6" />

        @* cara *@
        <path d="@FacePath(A.Face)" fill="url(#@_gSkin)" stroke="rgba(0,0,0,.10)" stroke-width="1" />

        @* mejillas suaves *@
        <ellipse cx="@F(50 - A.EyeSpread - 6)" cy="@F(A.EyeY + 13)" rx="6" ry="4" fill="#ff7a7a" opacity=".16" />
        <ellipse cx="@F(50 + A.EyeSpread + 6)" cy="@F(A.EyeY + 13)" rx="6" ry="4" fill="#ff7a7a" opacity=".16" />

        @if (A.Beard)
        {
            <g clip-path="url(#@_clip)">
                <path d="M 24 56 Q 50 94 76 56 L 76 80 Q 50 98 24 80 Z" fill="@Shade(A.HairColor, -10)" opacity="0.9" />
            </g>
        }

        @* ---- Cejas ---- *@
        <g transform="translate(@F(50 - A.EyeSpread),@A.BrowY)">@((MarkupString)Brow(A.Brows, false, A.HairColor))</g>
        <g transform="translate(@F(50 + A.EyeSpread),@A.BrowY)">@((MarkupString)Brow(A.Brows, true, A.HairColor))</g>

        @* ---- Ojos ---- *@
        <g transform="translate(@F(50 - A.EyeSpread),@A.EyeY) scale(@F(A.EyeSize / 100.0))">@((MarkupString)Eye(A.Eyes, A.EyeColor, false))</g>
        <g transform="translate(@F(50 + A.EyeSpread),@A.EyeY) scale(@F(A.EyeSize / 100.0))">@((MarkupString)Eye(A.Eyes, A.EyeColor, true))</g>

        @* ---- Nariz ---- *@
        <g transform="translate(50,@A.NoseY)">@((MarkupString)Nose(A.Nose, A.Skin))</g>

        @* ---- Boca ---- *@
        <g transform="translate(50,@A.MouthY) scale(@F(A.MouthSize / 100.0))">@((MarkupString)Mouth(A.Mouth))</g>

        @if (A.Glasses)
        {
            <g fill="rgba(180,210,235,.16)" stroke="@A.GlassesColor" stroke-width="2.2"
               transform="translate(0,@(A.EyeY - 50))">
                <rect x="@F(50 - A.EyeSpread - 9)" y="42" width="18" height="14" rx="6" />
                <rect x="@F(50 + A.EyeSpread - 9)" y="42" width="18" height="14" rx="6" />
                <line x1="@F(50 - A.EyeSpread + 9)" y1="47" x2="@F(50 + A.EyeSpread - 9)" y2="47" stroke-width="2.2" />
            </g>
        }

        @* pelo de adelante (flequillos) *@
        @((MarkupString)HairFront(A.Hair, A.HairColor, A.HairY, _gHair))
    </g>
</svg>

@code {
    [Parameter, EditorRequired] public Avatar A { get; set; } = new();
    [Parameter] public int Size { get; set; } = 120;
    /// <summary>Si true, dibuja también el torso con la camiseta.</summary>
    [Parameter] public bool Body { get; set; }
    [Parameter] public string Primary { get; set; } = "#e23b3b";
    [Parameter] public string Secondary { get; set; } = "#ffffff";

    private readonly string _uid = "a" + Guid.NewGuid().ToString("N")[..6];
    private string _clip => _uid + "c";
    private string _gSkin => _uid + "s";
    private string _gHair => _uid + "h";
    private string _gJersey => _uid + "j";

    public const int Faces = 5, Hairs = 8, EyesN = 6, BrowsN = 4, NosesN = 3, MouthsN = 6;

    // número con punto decimal, para que el SVG no dependa de la cultura (coma vs punto)
    private static string F(double v) => v.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);

    private static string FacePath(int f) => f switch
    {
        // ovalada suave
        0 => "M 50 13 C 71 13 80 30 80 50 C 80 73 67 89 50 89 C 33 89 20 73 20 50 C 20 30 29 13 50 13 Z",
        // redonda
        1 => "M 50 15 C 73 15 83 33 83 53 C 83 74 70 89 50 89 C 30 89 17 74 17 53 C 17 33 27 15 50 15 Z",
        // cuadrada de mentón marcado
        2 => "M 27 26 Q 27 17 40 16 Q 50 15 60 16 Q 73 17 73 26 L 80 50 Q 80 76 50 89 Q 20 76 20 50 Z",
        // corazón (mentón fino)
        3 => "M 50 15 C 73 15 82 31 79 50 C 76 73 61 89 50 89 C 39 89 24 73 21 50 C 18 31 27 15 50 15 Z",
        // alargada
        _ => "M 50 11 C 70 11 79 30 79 55 C 79 77 67 90 50 90 C 33 90 21 77 21 55 C 21 30 30 11 50 11 Z",
    };

    private static string HairBack(int h, int dy, string grad)
    {
        string d = h switch
        {
            1 => "M 13 44 Q 12 98 32 98 L 68 98 Q 88 98 87 44 Q 82 66 50 66 Q 18 66 13 44 Z",
            4 => "M 11 42 Q 8 104 34 104 L 66 104 Q 92 104 89 42 Q 82 70 50 70 Q 18 70 11 42 Z",
            6 => "M 50 4 C 78 4 90 28 90 48 C 90 60 84 66 78 66 L 22 66 C 16 66 10 60 10 48 C 10 28 22 4 50 4 Z",
            7 => "M 15 46 Q 14 92 30 100 L 34 78 Q 50 84 66 78 L 70 100 Q 86 92 85 46 Z",
            _ => "",
        };
        return string.IsNullOrEmpty(d) ? "" : $"<path transform='translate(0,{dy})' d='{d}' fill='url(#{grad})'/>";
    }

    private static string HairFront(int h, string c, int dy, string grad)
    {
        // silueta + un brillo diagonal encima
        string body = h switch
        {
            0 => "M 18 48 C 18 22 33 11 50 11 C 67 11 82 22 82 48 C 76 34 70 30 61 31 C 55 22 45 22 39 31 C 30 30 24 34 18 48 Z",
            1 => "M 16 52 C 13 24 33 11 50 11 C 67 11 87 24 84 52 C 79 36 71 31 63 33 C 57 23 43 23 37 33 C 29 31 21 36 16 52 Z",
            2 => "M 20 42 C 23 23 36 15 50 15 C 64 15 77 23 80 42 C 74 31 64 27 50 27 C 36 27 26 31 20 42 Z",
            3 => "M 18 48 C 18 20 35 11 50 11 C 65 11 82 20 82 48 C 77 35 70 31 62 33 L 57 21 L 51 33 L 45 21 L 40 33 C 32 31 25 35 18 48 Z",
            4 => "M 14 54 C 11 22 34 11 50 11 C 66 11 89 22 86 54 C 81 37 72 33 64 35 C 58 23 42 23 36 35 C 28 33 19 37 14 54 Z",
            5 => "M 22 38 C 26 22 37 15 50 15 C 63 15 74 22 78 38 C 68 33 60 45 50 41 C 40 45 32 33 22 38 Z",
            6 => "M 16 46 C 16 18 35 9 50 9 C 65 9 84 18 84 46 C 78 32 66 30 50 30 C 34 30 22 32 16 46 Z",
            7 => "M 17 50 C 15 24 34 12 50 12 C 66 12 85 24 83 50 C 76 32 70 46 58 40 C 52 30 42 44 34 40 C 26 44 22 34 17 50 Z",
            _ => "",
        };
        if (string.IsNullOrEmpty(body)) return "";
        string shine = $"<path d='M 30 20 Q 42 13 55 17' fill='none' stroke='{Shade(c, 40)}' stroke-width='3.2' stroke-linecap='round' opacity='.45'/>";
        return $"<g transform='translate(0,{dy})'><path d='{body}' fill='url(#{grad})'/>{shine}</g>";
    }

    // ---- Un ojo, centrado en (0,0). Con brillo (catchlight) para que se vea vivo ----
    private static string Eye(int e, string c, bool derecho)
    {
        int s = derecho ? -1 : 1;
        string lid = $"<path d='M -6 -3.5 Q 0 -7 6 -3.5' fill='none' stroke='rgba(0,0,0,.35)' stroke-width='1.4' stroke-linecap='round'/>";
        string shine = "<circle cx='-1.6' cy='-2' r='1.3' fill='#fff'/>";
        return e switch
        {
            // almendra normal
            0 => $"<ellipse cx='0' cy='0' rx='5.4' ry='6.2' fill='#fff'/><circle cx='0' cy='0.6' r='3.5' fill='{c}'/><circle cx='0' cy='0.6' r='1.7' fill='#1a1a1a'/>{shine}{lid}",
            // grande redondo
            1 => $"<ellipse cx='0' cy='0' rx='6.2' ry='7' fill='#fff'/><circle cx='0' cy='0.8' r='4.2' fill='{c}'/><circle cx='0' cy='0.8' r='2' fill='#1a1a1a'/>{shine}{lid}",
            // dormilón (arco cerrado hacia abajo)
            2 => $"<path d='M {-6 * s} -1 Q 0 4 {6 * s} -1' fill='none' stroke='#2a2a2a' stroke-width='2.4' stroke-linecap='round'/>",
            // ancho ovalado
            3 => $"<ellipse cx='0' cy='0' rx='6' ry='5.2' fill='#fff'/><circle cx='0' cy='0.4' r='3.4' fill='{c}'/><circle cx='0' cy='0.4' r='1.6' fill='#1a1a1a'/>{shine}{lid}",
            // feliz (arco hacia arriba, ojito cerrado)
            4 => $"<path d='M {-6 * s} 1 Q 0 -5 {6 * s} 1' fill='none' stroke='#2a2a2a' stroke-width='2.4' stroke-linecap='round'/>",
            // decidido (mirada afilada)
            _ => $"<path d='M -6 -1.5 Q 0 -4 6 -1.5 L 6 1 Q 0 3.5 -6 1 Z' fill='#fff'/><circle cx='{F(1.4 * s)}' cy='0' r='3' fill='{c}'/><circle cx='{F(1.4 * s)}' cy='0' r='1.5' fill='#1a1a1a'/><circle cx='{F(0.2 * s)}' cy='-1.3' r='1' fill='#fff'/>",
        };
    }

    private static string Brow(int b, bool derecho, string c)
    {
        int s = derecho ? -1 : 1;
        string col = Shade(c, -30);
        return b switch
        {
            0 => $"<path d='M {-6 * s} 0 Q 0 -3 {6 * s} 0.5' fill='none' stroke='{col}' stroke-width='2.6' stroke-linecap='round'/>",
            1 => $"<path d='M {-6 * s} 0 L {6 * s} 0' stroke='{col}' stroke-width='2.8' stroke-linecap='round'/>",
            2 => $"<path d='M {-6 * s} 2 Q 0 -2.5 {6 * s} 0.5' fill='none' stroke='{col}' stroke-width='2.8' stroke-linecap='round'/>",
            _ => $"<path d='M {-6 * s} 0.5 Q 0 3.5 {6 * s} 0.5' fill='none' stroke='{col}' stroke-width='2.6' stroke-linecap='round'/>",
        };
    }

    private static string Nose(int n, string skin) => n switch
    {
        0 => $"<path d='M -0.5 -5 Q -3.5 3 0 4 Q 3.5 3 0.5 -5' fill='{Shade(skin, -14)}' opacity='.7'/><ellipse cx='-1.6' cy='3' rx='1.1' ry='.8' fill='{Shade(skin, -28)}' opacity='.5'/><ellipse cx='1.6' cy='3' rx='1.1' ry='.8' fill='{Shade(skin, -28)}' opacity='.5'/>",
        1 => $"<path d='M -2 -4 Q 0 5 2.5 -3' fill='none' stroke='{Shade(skin, -26)}' stroke-width='1.8' stroke-linecap='round' opacity='.75'/>",
        _ => $"<ellipse cx='0' cy='1' rx='3' ry='2.2' fill='{Shade(skin, -18)}' opacity='.6'/>",
    };

    private static string Mouth(int m) => m switch
    {
        // sonrisa suave
        0 => "<path d='M -9 -1 Q 0 6 9 -1' fill='none' stroke='#a34b42' stroke-width='2.6' stroke-linecap='round'/>",
        // neutra
        1 => "<path d='M -7 0 L 7 0' stroke='#a34b42' stroke-width='2.6' stroke-linecap='round'/>",
        // seria (leve hacia abajo)
        2 => "<path d='M -9 2 Q 0 -3 9 2' fill='none' stroke='#a34b42' stroke-width='2.6' stroke-linecap='round'/>",
        // sonrisa con dientes
        3 => "<path d='M -10 -2 Q 0 3 10 -2 Q 0 10 -10 -2 Z' fill='#8f3b34'/><path d='M -8 -0.6 Q 0 1.6 8 -0.6 Q 0 3.2 -8 -0.6 Z' fill='#fff'/>",
        // boca abierta (sorpresa)
        4 => "<ellipse cx='0' cy='1' rx='4.6' ry='5.6' fill='#8f3b34'/><ellipse cx='0' cy='3' rx='3' ry='2.4' fill='#c65b52'/>",
        // sonrisa grande con labios
        _ => "<path d='M -10 -2 Q 0 2 10 -2 Q 6 8 0 8 Q -6 8 -10 -2 Z' fill='#b85049'/><path d='M -8 -1 Q 0 1.2 8 -1 Q 0 3 -8 -1 Z' fill='#fff'/>",
    };

    private static string Shade(string hex, int d)
    {
        if (hex.Length != 7) return hex;
        int C(int i) => Math.Clamp(Convert.ToInt32(hex.Substring(i, 2), 16) + d, 0, 255);
        return $"#{C(1):x2}{C(3):x2}{C(5):x2}";
    }
}
