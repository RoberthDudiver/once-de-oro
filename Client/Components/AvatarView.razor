@* Avatar 2D (estilo Mii plano) dibujado por código en SVG. Cada rasgo se posiciona
   y escala con los valores de ajuste fino, así se puede "estirar" la cara. *@
@using OnceDeOro.Models

<svg class="avatar" viewBox="0 0 100 @(Body ? 130 : 100)" width="@Size" height="@(Body ? Size * 1.3 : Size)"
     role="img" aria-label="@(string.IsNullOrEmpty(A.Name) ? "Avatar" : A.Name)">
    <defs>
        <clipPath id="@_clip"><path d="@FacePath(A.Face)" /></clipPath>
    </defs>

    @* ---------- Cuerpo (torso con la camiseta del club) ---------- *@
    @if (Body)
    {
        <g transform="translate(0,2)">
            @* cuello *@
            <rect x="43" y="84" width="14" height="12" rx="4" fill="@A.Skin" />
            @* camiseta *@
            <path d="M 30 96 L 42 90 Q 50 96 58 90 L 70 96 L 78 104 L 72 112 L 72 130 L 28 130 L 28 112 L 22 104 Z"
                  fill="@Primary" stroke="rgba(0,0,0,.12)" stroke-width="1" />
            @* franja del color secundario y cuello de la camiseta *@
            <path d="M 42 90 Q 50 98 58 90 L 55 94 Q 50 100 45 94 Z" fill="@Secondary" />
            <rect x="46" y="104" width="8" height="26" fill="@Secondary" opacity="0.9" />
            @* mangas *@
            <path d="M 30 96 L 22 104 L 27 110 L 33 100 Z" fill="@Secondary" />
            <path d="M 70 96 L 78 104 L 73 110 L 67 100 Z" fill="@Secondary" />
        </g>
    }

    @* ---------- Cabeza, escalada en ancho por FaceW ---------- *@
    <g transform="translate(50,0) scale(@F(A.FaceW / 100.0),1) translate(-50,0)">
        @* pelo de atrás (nuca) *@
        @((MarkupString)HairBack(A.Hair, A.HairColor, A.HairY))

        <path d="@FacePath(A.Face)" fill="@A.Skin" stroke="rgba(0,0,0,.14)" stroke-width="1" />
        <circle cx="16" cy="52" r="6" fill="@A.Skin" stroke="rgba(0,0,0,.10)" stroke-width="1" />
        <circle cx="84" cy="52" r="6" fill="@A.Skin" stroke="rgba(0,0,0,.10)" stroke-width="1" />

        @if (A.Beard)
        {
            <g clip-path="url(#@_clip)">
                <path d="M 26 58 Q 50 92 74 58 L 74 78 Q 50 96 26 78 Z" fill="@Darken(A.HairColor)" opacity="0.92" />
            </g>
        }

        @* ---- Cejas (dos instancias, separadas y a la altura ajustada) ---- *@
        <g transform="translate(@F(50 - A.EyeSpread),@A.BrowY)">@((MarkupString)Brow(A.Brows, false))</g>
        <g transform="translate(@F(50 + A.EyeSpread),@A.BrowY)">@((MarkupString)Brow(A.Brows, true))</g>

        @* ---- Ojos (posición + separación + tamaño) ---- *@
        <g transform="translate(@F(50 - A.EyeSpread),@A.EyeY) scale(@F(A.EyeSize / 100.0))">@((MarkupString)Eye(A.Eyes, A.EyeColor, false))</g>
        <g transform="translate(@F(50 + A.EyeSpread),@A.EyeY) scale(@F(A.EyeSize / 100.0))">@((MarkupString)Eye(A.Eyes, A.EyeColor, true))</g>

        @* ---- Nariz ---- *@
        <g transform="translate(50,@A.NoseY)">@((MarkupString)Nose(A.Nose))</g>

        @* ---- Boca ---- *@
        <g transform="translate(50,@A.MouthY) scale(@F(A.MouthSize / 100.0))">@((MarkupString)Mouth(A.Mouth))</g>

        @if (A.Glasses)
        {
            <g fill="none" stroke="@A.GlassesColor" stroke-width="2.4"
               transform="translate(0,@(A.EyeY - 50))">
                <rect x="@F(50 - A.EyeSpread - 9)" y="42" width="18" height="13" rx="4" />
                <rect x="@F(50 + A.EyeSpread - 9)" y="42" width="18" height="13" rx="4" />
                <line x1="@F(50 - A.EyeSpread + 9)" y1="47" x2="@F(50 + A.EyeSpread - 9)" y2="47" />
            </g>
        }

        @* pelo de adelante (flequillos) *@
        @((MarkupString)HairFront(A.Hair, A.HairColor, A.HairY))
    </g>
</svg>

@code {
    [Parameter, EditorRequired] public Avatar A { get; set; } = new();
    [Parameter] public int Size { get; set; } = 120;
    /// <summary>Si true, dibuja también el torso con la camiseta.</summary>
    [Parameter] public bool Body { get; set; }
    [Parameter] public string Primary { get; set; } = "#e23b3b";
    [Parameter] public string Secondary { get; set; } = "#ffffff";

    private readonly string _clip = "fc" + Guid.NewGuid().ToString("N")[..6];

    public const int Faces = 5, Hairs = 8, EyesN = 6, BrowsN = 4, NosesN = 3, MouthsN = 6;

    // número con punto decimal, para que el SVG no dependa de la cultura (coma vs punto)
    private static string F(double v) => v.ToString("0.###", System.Globalization.CultureInfo.InvariantCulture);

    private static string FacePath(int f) => f switch
    {
        0 => "M 50 12 C 74 12 82 30 82 50 C 82 74 68 88 50 88 C 32 88 18 74 18 50 C 18 30 26 12 50 12 Z",
        1 => "M 50 14 C 76 14 84 34 84 52 C 84 70 74 88 50 88 C 26 88 16 70 16 52 C 16 34 24 14 50 14 Z",
        2 => "M 24 20 L 76 20 Q 82 20 82 30 L 82 66 Q 82 88 50 88 Q 18 88 18 66 L 18 30 Q 18 20 24 20 Z",
        3 => "M 50 14 C 74 14 82 30 80 48 C 78 68 66 88 50 88 C 34 88 22 68 20 48 C 18 30 26 14 50 14 Z",
        _ => "M 50 10 C 72 10 80 30 80 54 C 80 76 68 90 50 90 C 32 90 20 76 20 54 C 20 30 28 10 50 10 Z",
    };

    private static string HairBack(int h, string c, int dy) => h switch
    {
        1 => $"<path transform='translate(0,{dy})' d='M 14 46 Q 14 96 30 96 L 70 96 Q 86 96 86 46 Z' fill='{c}'/>",
        4 => $"<path transform='translate(0,{dy})' d='M 12 44 Q 10 100 34 100 L 66 100 Q 90 100 88 44 Z' fill='{c}'/>",
        6 => $"<circle transform='translate(0,{dy})' cx='50' cy='42' r='40' fill='{c}'/>",
        _ => "",
    };

    private static string HairFront(int h, string c, int dy)
    {
        string body = h switch
        {
            0 => $"<path d='M 18 46 C 18 20 34 10 50 10 C 66 10 82 20 82 46 C 74 30 70 28 62 30 C 56 22 44 22 38 30 C 30 28 26 30 18 46 Z' fill='{c}'/>",
            1 => $"<path d='M 16 50 C 14 22 34 10 50 10 C 66 10 86 22 84 50 C 80 34 72 30 64 32 C 58 22 42 22 36 32 C 28 30 20 34 16 50 Z' fill='{c}'/>",
            2 => $"<path d='M 20 40 C 24 22 36 14 50 14 C 64 14 76 22 80 40 C 76 30 66 26 50 26 C 34 26 24 30 20 40 Z' fill='{c}'/>",
            3 => $"<path d='M 18 46 C 18 18 36 10 50 10 C 64 10 82 18 82 46 C 78 34 70 30 62 32 L 58 20 L 52 32 L 46 20 L 42 32 C 34 30 26 32 18 46 Z' fill='{c}'/>",
            4 => $"<path d='M 14 52 C 12 20 34 10 50 10 C 66 10 88 20 86 52 C 82 36 74 32 66 34 C 60 22 40 22 34 34 C 26 32 18 36 14 52 Z' fill='{c}'/>",
            5 => $"<path d='M 22 36 C 26 20 38 14 50 14 C 62 14 74 20 78 36 C 68 30 60 44 50 40 C 40 44 32 30 22 36 Z' fill='{c}'/>",
            6 => $"<path d='M 16 44 C 16 16 36 8 50 8 C 64 8 84 16 84 44 C 78 30 66 28 50 28 C 34 28 22 30 16 44 Z' fill='{c}'/>",
            _ => "",
        };
        return string.IsNullOrEmpty(body) ? "" : $"<g transform='translate(0,{dy})'>{body}</g>";
    }

    // ---- Un ojo, dibujado centrado en (0,0) para poder posicionarlo con transform ----
    private static string Eye(int e, string c, bool derecho)
    {
        int s = derecho ? -1 : 1;   // espejo horizontal para el ojo derecho
        string m = e switch
        {
            0 => "<ellipse cx='0' cy='0' rx='5' ry='6' fill='#fff'/><circle cx='0' cy='0' r='3' fill='{C}'/>",
            1 => "<circle cx='0' cy='0' r='4' fill='{C}'/>",
            2 => $"<path d='M {-6*s} 0 Q 0 -7 {6*s} 0' fill='none' stroke='{{C}}' stroke-width='2.6' stroke-linecap='round'/>",
            3 => "<ellipse cx='0' cy='0' rx='6' ry='7' fill='#fff'/><circle cx='1' cy='1' r='3.4' fill='{C}'/>",
            4 => $"<path d='M {-6*s} 0 Q 0 5 {6*s} 0' fill='none' stroke='{{C}}' stroke-width='2.6' stroke-linecap='round'/>",
            _ => "<rect x='-5.5' y='-2.5' width='11' height='5' rx='2.5' fill='#fff' stroke='{C}' stroke-width='1.4'/><circle cx='0' cy='0.5' r='2.4' fill='{C}'/>",
        };
        return m.Replace("{C}", c);
    }

    private static string Brow(int b, bool derecho)
    {
        int s = derecho ? -1 : 1;
        return b switch
        {
            0 => $"<path d='M {-6*s} 0 Q 0 -3 {6*s} 0' fill='none' stroke='#3a2c1c' stroke-width='2.4' stroke-linecap='round'/>",
            1 => $"<line x1='{-6*s}' y1='0' x2='{6*s}' y2='0' stroke='#3a2c1c' stroke-width='2.6' stroke-linecap='round'/>",
            2 => $"<path d='M {-6*s} 2 Q 0 -2 {6*s} 1' fill='none' stroke='#3a2c1c' stroke-width='2.6' stroke-linecap='round'/>",
            _ => $"<path d='M {-6*s} 1 Q 0 4 {6*s} 1' fill='none' stroke='#3a2c1c' stroke-width='2.4' stroke-linecap='round'/>",
        };
    }

    // nariz centrada en (0,0)
    private static string Nose(int n) => n switch
    {
        0 => "<path d='M 0 -6 L -3 3 Q 0 6 3 3 Z' fill='rgba(0,0,0,.10)'/>",
        1 => "<path d='M -2 -4 Q 0 6 2 -4' fill='none' stroke='rgba(0,0,0,.22)' stroke-width='2' stroke-linecap='round'/>",
        _ => "<ellipse cx='0' cy='0' rx='3.5' ry='2.4' fill='rgba(0,0,0,.12)'/>",
    };

    // boca centrada en (0,0)
    private static string Mouth(int m) => m switch
    {
        0 => "<path d='M -10 -1 Q 0 7 10 -1' fill='none' stroke='#7a3b34' stroke-width='2.6' stroke-linecap='round'/>",
        1 => "<line x1='-8' y1='0' x2='8' y2='0' stroke='#7a3b34' stroke-width='2.6' stroke-linecap='round'/>",
        2 => "<path d='M -10 3 Q 0 -5 10 3' fill='none' stroke='#7a3b34' stroke-width='2.6' stroke-linecap='round'/>",
        3 => "<path d='M -10 -2 Q 0 9 10 -2 Q 0 3 -10 -2 Z' fill='#a24b42'/>",
        4 => "<ellipse cx='0' cy='1' rx='5' ry='6' fill='#7a3b34'/>",
        _ => "<path d='M -10 -1 Q 0 6 10 -1' fill='none' stroke='#7a3b34' stroke-width='2.6' stroke-linecap='round'/>",
    };

    private static string Darken(string hex)
    {
        if (hex.Length != 7) return hex;
        int R(int i) => Math.Max(0, Convert.ToInt32(hex.Substring(i, 2), 16) - 24);
        return $"#{R(1):x2}{R(3):x2}{R(5):x2}";
    }
}
