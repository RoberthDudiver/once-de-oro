@* Carta de jugador con estética coleccionable *@
<div class="pcard @(P.IsLegend ? "pcard--legend" : "")">
    <div class="pcard__rating" data-tier="@Tier">@P.Rating</div>
    <div class="pcard__body">
        <div class="pcard__name">
            @P.Name
            @if (P.IsLegend) { <span class="star">★</span> }
        </div>
        <div class="pcard__meta">
            <span class="pcard__flag">@P.Flag</span>
            <span class="pos pos--@P.Pos">@P.Pos.Label()</span>
            <span class="faint">·</span>
            <span>@P.Nation</span>
        </div>
    </div>
    <div class="pcard__right">
        @if (ShowPrice)
        {
            <div class="pcard__price">
                @Price<small> M</small>
            </div>
        }
        @Actions
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Player P { get; set; } = default!;
    [Parameter] public bool ShowPrice { get; set; } = true;
    [Parameter] public int Price { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }

    private string Tier => P.Rating >= 85 ? "gold" : P.Rating >= 75 ? "silver" : "bronze";
}
