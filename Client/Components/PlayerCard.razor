@* Carta de jugador con estética coleccionable *@
@inject GameService Game
<div class="pcard @(P.IsLegend ? "pcard--legend" : "")" @onclick="OpenDetail">
    <div class="pcard__rating" data-tier="@Tier">@P.Rating</div>
    <div class="pcard__body">
        <div class="pcard__name">
            @P.Name
            @if (P.IsLegend) { <span class="star">★</span> }
        </div>
        <div class="pcard__meta">
            <span class="pcard__flag">@P.Flag</span>
            <span class="pos pos--@P.Pos">@P.Pos.Label()</span>
            <span class="faint">·</span>
            <span>@P.Nation</span>
        </div>
        @{ var cond = Game.State.Conditions.TryGetValue(P.Id, out var cc) ? cc : null; }
        @if (cond is not null && (cond.Injured || cond.Suspended > 0 || cond.Fatigue >= 45))
        {
            <div class="pcard__flags">
                @if (cond.Injured) { <span class="tag-inj">🚑 @cond.OutMatches</span> }
                else if (cond.Suspended > 0) { <span class="tag-ban">🟥 @cond.Suspended</span> }
                else { <span class="tag-fat">😮‍💨 @cond.Fatigue%</span> }
            </div>
        }
    </div>
    @* Los botones de acción no deben abrir la ficha *@
    <div class="pcard__right" @onclick:stopPropagation="true">
        @if (ShowPrice)
        {
            <div class="pcard__price">
                @Price<small> M</small>
            </div>
        }
        @Actions
    </div>
</div>

@code {
    [Parameter, EditorRequired] public Player P { get; set; } = default!;
    [Parameter] public bool ShowPrice { get; set; } = true;
    [Parameter] public int Price { get; set; }
    [Parameter] public RenderFragment? Actions { get; set; }

    /// <summary>Al tocar la carta se abre la ficha completa del jugador.</summary>
    [Parameter] public EventCallback<Player> OnOpen { get; set; }

    private Task OpenDetail() => OnOpen.HasDelegate ? OnOpen.InvokeAsync(P) : Task.CompletedTask;

    private string Tier => P.Rating >= 85 ? "gold" : P.Rating >= 75 ? "silver" : "bronze";
}
