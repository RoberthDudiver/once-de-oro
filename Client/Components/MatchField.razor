@* Cancha 2D vista desde arriba: reproduce el timeline con 22 jugadores + pelota *@
@using OnceDeOro.Models
@using OnceDeOro.Data
@inject Loc Loc
@inject Sfx Sfx
@inject GameService Game

<div class="mf">
    @if (_goalId > 0)
    {
        <div class="goalflash" @key="_goalId"><span>@_goalText</span></div>
    }

    @if (!string.IsNullOrEmpty(Round))
    {
        <div class="mf__round">@Round</div>
    }

    <div class="mf__hud">
        <div class="mf__team">
            <span class="mf__flag">@HomeFlag</span>
            <span class="mf__tname">@Short(HomeName)</span>
        </div>
        <div class="mf__score">
            <span class="board__num" @key='("h", _hs)'>@_hs</span>
            <span class="sep">–</span>
            <span class="board__num" @key='("a", _as)'>@_as</span>
        </div>
        <div class="mf__team mf__team--r">
            <span class="mf__tname">@Short(AwayName)</span>
            <span class="mf__flag">@AwayFlag</span>
        </div>
    </div>
    <div class="mf__clock">
        <span class="mf__phase">@PhaseLabel</span>
        <span class="mf__min">@ClockLabel</span>
        @if (_pens is not null) { <span class="mf__pens">PEN @_pens</span> }
    </div>

    @if (!_done)
    {
        <div class="mf__controls mf__controls--top">
            <div class="seg">
                <button class="@(_speed == 1.0 ? "on" : "")" @onclick="() => SetSpeed(1.0)">1×</button>
                <button class="@(_speed == 0.5 ? "on" : "")" @onclick="() => SetSpeed(0.5)">2×</button>
                <button class="@(_speed == 0.25 ? "on" : "")" @onclick="() => SetSpeed(0.25)">4×</button>
            </div>
            <button class="btn btn--ghost" @onclick="ToggleSonido" title="@Loc["Sonido"]">@(_sonido ? "🔊" : "🔇")</button>
            <button class="btn btn--ghost" @onclick="Saltar">@Loc["⏩ Saltar al final"]</button>
        </div>
    }

    @if (_phase == MatchPhase.Shootout)
    {
        @* ---------- Tanda de penales ---------- *@
        <div class="pk">
            <div class="pk__scene">
                <div class="pk__net"></div>
                <div class="pk__keeper @_penKeeperClass" @key='"k" + _penKickId'></div>
                <div class="pk__ball @_penBallClass" @key='"b" + _penKickId'></div>
                @if (_penTaker is not null)
                {
                    <div class="pk__taker">@_penTaker <span>@(_penScored ? "⚽ GOL" : "🧤 ATAJADO")</span></div>
                }
            </div>
            <div class="pk__rows">
                <div class="pk__row">
                    <span class="pk__flag">@HomeFlag</span> <b>@Short(HomeName)</b>
                    @for (int i = 0; i < 5 || i < _homePens.Count; i++)
                    {
                        var mk = i < _homePens.Count ? (_homePens[i] ? "sc" : "ms") : "";
                        <span class="pk__mk @mk"></span>
                    }
                </div>
                <div class="pk__row">
                    <span class="pk__flag">@AwayFlag</span> <b>@Short(AwayName)</b>
                    @for (int i = 0; i < 5 || i < _awayPens.Count; i++)
                    {
                        var mk = i < _awayPens.Count ? (_awayPens[i] ? "sc" : "ms") : "";
                        <span class="pk__mk @mk"></span>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        @* La cancha del partido tambien juega en TU estadio: mismos colores y
           mismas gradas que elegiste en Equipo. *@
        <div class="stadium stadium--match" data-stands="@Game.State.Stands"
             style="--c1:@Game.State.Primary; --c2:@Game.State.Secondary; --grada:@(Game.Stadium.GradaPx)px;">
        <div class="stand"></div>
        <div class="mf__pitch" style="--t:@($"{_stepSec.ToString(System.Globalization.CultureInfo.InvariantCulture)}s")">
            <div class="mf__mid"></div>
            <div class="mf__circle"></div>
            <div class="mf__box mf__box--l"></div>
            <div class="mf__box mf__box--r"></div>
            <div class="mf__goal mf__goal--l"></div>
            <div class="mf__goal mf__goal--r"></div>

            @for (int i = 0; i < 11; i++)
            {
                var idx = i;
                <div class="mf__p mf__p--home @(idx == 0 ? "gk" : "")" @key='("h" + idx)'
                     style="left:@Pct(_hx[idx]);top:@Pct(_hy[idx]);">
                    @if (_homeNames[idx].Length > 0) { <span class="mf__pn">@_homeNames[idx]</span> }
                </div>
            }
            @for (int i = 0; i < 11; i++)
            {
                var idx = i;
                <div class="mf__p mf__p--away @(idx == 0 ? "gk" : "")" @key='("a" + idx)'
                     style="left:@Pct(_ax[idx]);top:@Pct(_ay[idx]);">
                    @if (_awayNames[idx].Length > 0) { <span class="mf__pn">@_awayNames[idx]</span> }
                </div>
            }
            <div class="mf__ball @_ballClass" style="left:@Pct(_bx);top:@Pct(_by);"></div>

            @if (_banner is not null)
            {
                <div class="mf__banner" @key="_bannerId"><span>@_banner</span></div>
            }
        </div>
        </div>
    }

    <div class="mf__ticker">@_ticker</div>

    <div class="mf__stats">
        <div class="mf__stat"><b>@_st.PossHome%</b><span>@Loc["Posesión"]</span><b>@_st.PossAway%</b></div>
        <div class="mf__statbar"><span style="width:@(_st.PossHome)%"></span></div>
        <div class="mf__statrow"><b>@_st.ShotsHome</b><span>@Loc["Remates"]</span><b>@_st.ShotsAway</b></div>
        <div class="mf__statrow"><b>@_st.CornersHome</b><span>@Loc["Corners"]</span><b>@_st.CornersAway</b></div>
        <div class="mf__statrow"><b>@_st.FoulsHome</b><span>@Loc["Faltas"]</span><b>@_st.FoulsAway</b></div>
        <div class="mf__statrow"><b>@_st.YellowHome/@_st.RedHome</b><span>🟨 / 🟥</span><b>@_st.YellowAway/@_st.RedAway</b></div>
    </div>

    @if (_keyEvents.Count > 0)
    {
        <div class="mf__events">
            @foreach (var ev in _keyEvents)
            {
                <div class="mf__ev @ev.Side">
                    <span class="mf__ev-min">@ev.Min'</span>
                    <span class="mf__ev-ico">@ev.Ico</span>
                    <span class="mf__ev-txt">@ev.Txt</span>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public MatchTimeline Timeline { get; set; } = default!;
    [Parameter] public string HomeName { get; set; } = "Local";
    [Parameter] public string AwayName { get; set; } = "Visitante";
    [Parameter] public string HomeFlag { get; set; } = "⚽";
    [Parameter] public string AwayFlag { get; set; } = "⚽";
    [Parameter] public string HomeFormationName { get; set; } = "4-3-3";
    [Parameter] public string AwayFormationName { get; set; } = "4-3-3";
    [Parameter] public IReadOnlyList<Player>? HomeStarters { get; set; }
    [Parameter] public IReadOnlyList<Player>? AwayStarters { get; set; }
    [Parameter] public string? Round { get; set; }
    [Parameter] public EventCallback OnFinished { get; set; }

    private readonly int[] _corners = new int[2];
    private readonly double[] _hx = new double[11], _hy = new double[11], _ax = new double[11], _ay = new double[11];
    // Arrancan VACÍOS, nunca null: el componente puede renderizarse antes de que
    // OnInitializedAsync termine (basta un await), y el render lee .Length.
    private readonly string[] _homeNames = Enumerable.Repeat("", 11).ToArray();
    private readonly string[] _awayNames = Enumerable.Repeat("", 11).ToArray();
    private (double x, double y)[] _homeBase = default!, _awayBase = default!;
    private double _bx = 0.5, _by = 0.5;
    private string _ballClass = "";
    private int _hs, _as, _clockSec;
    private string? _pens;
    private MatchPhase _phase = MatchPhase.First;
    private string _ticker = "Preparados…";
    private string? _banner;
    private int _bannerId, _goalId;
    private string _goalText = "¡GOOOL!";
    private bool _done, _skip;
    private double _speed = 0.5, _stepSec = 0.4;
    private MatchStats _st = new();
    private readonly Random _rng = new();
    private readonly int[] _possCount = new int[2];

    private record KeyEv(int Min, string Ico, string Txt, string Side);
    private readonly List<KeyEv> _keyEvents = new();

    // Tanda de penales
    private readonly List<bool> _homePens = new(), _awayPens = new();
    private List<string> _homeTakers = new(), _awayTakers = new();
    private int _penKickId;
    private bool _penScored;
    private string? _penTaker, _penBallClass = "", _penKeeperClass = "";

    private bool _sonido = true;

    private async Task ToggleSonido()
    {
        _sonido = await Sfx.ToggleAsync();
        if (!_sonido) { Sfx.CrowdStop(); Sfx.MusicStop(); }
        else AjustarSonido();          // vuelve el ambiente o la música, según la velocidad
    }

    protected override async Task OnInitializedAsync()
    {
        // TODO lo sincrónico va PRIMERO: el primer await cede el control y Blazor
        // renderiza, así que el estado que usa el render ya tiene que estar listo.
        _homeBase = BasePositions(Formation.All.FirstOrDefault(f => f.Name == HomeFormationName) ?? Formation.F433, true);
        _awayBase = BasePositions(Formation.All.FirstOrDefault(f => f.Name == AwayFormationName) ?? Formation.F433, false);
        for (int i = 0; i < 11; i++)
        {
            (_hx[i], _hy[i]) = _homeBase[i]; (_ax[i], _ay[i]) = _awayBase[i];
        }
        CargarNombres();
        _iniciado = true;

        await Sfx.LoadAsync();
        _sonido = Sfx.On;
        await Play();
    }

    [Parameter] public bool PararEnEntretiempo { get; set; }
    [Parameter] public EventCallback OnEntretiempo { get; set; }

    private TaskCompletionSource? _seguir;
    private bool _iniciado;

    /// <summary>
    /// Relee los nombres del XI en la cancha. Se llama al reanudar el 2T: si el DT
    /// metió un cambio, el que entró tiene que APARECER con su nombre. Antes esto
    /// sólo pasaba al inicio, y por eso el cambio "no se notaba".
    /// </summary>
    private void CargarNombres()
    {
        for (int i = 0; i < 11; i++)
        {
            _homeNames[i] = NameAt(HomeStarters, i);
            _awayNames[i] = NameAt(AwayStarters, i);
        }
        _homeTakers = Takers(HomeStarters, HomeName);
        _awayTakers = Takers(AwayStarters, AwayName);
    }

    // Cuando el padre re-renderiza con un XI nuevo (un cambio del DT), Blazor
    // actualiza HomeStarters y pasa por acá: recargamos los nombres para que el
    // que entró APAREZCA. Antes esto lo hacía Reanudar(), que corría ANTES del
    // re-render del padre y leía el XI viejo — por eso el cambio no se veía.
    protected override void OnParametersSet()
    {
        if (_iniciado) CargarNombres();
    }

    /// <summary>Lo llama la pantalla del partido cuando el DT termina en el vestuario.</summary>
    public void Reanudar() => _seguir?.TrySetResult();

    private async Task Play()
    {
        // Se recorre por INDICE y releyendo Count: el segundo tiempo se agrega a
        // esta misma lista mientras el partido está pausado, y así sigue solo.
        for (int i = 0; i < Timeline.Events.Count; i++)
        {
            var e = Timeline.Events[i];
            Apply(e);

            if (PararEnEntretiempo && e.Type == SimEventType.HalfTime)
            {
                _done = false;
                StateHasChanged();
                _seguir = new TaskCompletionSource();
                await OnEntretiempo.InvokeAsync();
                await _seguir.Task;          // espera a que el DT cierre el vestuario
                _seguir = null;
            }
            _stepSec = Math.Max(0.12, e.Dur * _speed);
            StateHasChanged();
            int ms = (int)(e.Dur * 1000 * (_skip ? 0.02 : _speed));
            await Task.Delay(Math.Max(6, ms));
        }
        _done = true;
        Sfx.CrowdStop();
        Sfx.MusicStop();
        StateHasChanged();
        await OnFinished.InvokeAsync();
    }

    private void Apply(SimEvent e)
    {
        _clockSec = e.Clock;
        _phase = e.Phase;

        bool live = e.Type is SimEventType.KickOff or SimEventType.Pass or SimEventType.Carry
                            or SimEventType.Shot or SimEventType.Goal or SimEventType.Save
                            or SimEventType.Post or SimEventType.Miss or SimEventType.Foul
                            or SimEventType.PenaltyAwarded
                            // Sin esto la pelota NO viaja al banderin ni al lateral y la
                            // jugada queda invisible: solo se veria el texto.
                            or SimEventType.Corner or SimEventType.ThrowIn
                            or SimEventType.FreeKick or SimEventType.FreeKickIndirect;

        if (live)
        {
            _bx = e.BallX; _by = e.BallY;
            _ballClass = e.Type is SimEventType.Shot or SimEventType.Goal ? "shot" : "";

            // Las jugadas detenidas se arman a mano: en un penal la gente sale del
            // area, en un corner se amontona en el area y alguien va al banderin.
            // Con el seguimiento generico la pelota viajaba sola y los 22 se
            // quedaban parados en su formacion, que es lo que se veia falso.
            if (!JugadaDetenida(e))
            {
            for (int t = 0; t < 2; t++)
            {
                bool attacking = e.Team == t;
                var bx = t == 0 ? _hx : _ax;
                var by = t == 0 ? _hy : _ay;
                var baseP = t == 0 ? _homeBase : _awayBase;
                for (int i = 0; i < 11; i++)
                {
                    // El arquero (i==0) NO se mueve del arco. El resto mantiene la forma
                    // de la formación y sólo se corre un poco hacia la pelota (sin amontonarse).
                    double follow = i == 0 ? 0.0 : (attacking ? 0.16 : 0.07);
                    double followY = i == 0 ? 0.03 : (attacking ? 0.11 : 0.05);
                    double jit = i == 0 ? 0 : (_rng.NextDouble() - 0.5) * 0.02;
                    double tx = baseP[i].x + (_bx - baseP[i].x) * follow;
                    double ty = baseP[i].y + (_by - baseP[i].y) * followY + jit;
                    // los jugadores nunca se pegan al borde (para que no se salgan / se corte el nombre)
                    bx[i] = Math.Clamp(tx, 0.09, 0.91);
                    by[i] = Math.Clamp(ty, 0.10, 0.90);
                }
            }
            // El jugador en posesión (nunca el arquero, índice 0) se para en la pelota.
            if (e.Team is 0 or 1 && e.Player is >= 1 and < 11 && e.Type is SimEventType.Pass or SimEventType.Carry or SimEventType.Shot or SimEventType.Goal)
            {
                var bx = e.Team == 0 ? _hx : _ax;
                var by = e.Team == 0 ? _hy : _ay;
                bx[e.Player] = _bx; by[e.Player] = _by;
            }
            }
            if (e.Type is SimEventType.Pass or SimEventType.Carry && e.Team is 0 or 1)
                _possCount[e.Team]++;
        }

        Sonar(e);

        switch (e.Type)
        {
            case SimEventType.Goal:
                if (e.Team == 0) _hs++; else _as++;
                _goalId++; _goalText = "¡GOOOL!";
                AddKey(SimEventType.Goal, e);
                break;
            case SimEventType.Yellow: AddKey(SimEventType.Yellow, e); break;
            case SimEventType.Red: AddKey(SimEventType.Red, e); break;
            case SimEventType.Injury: AddKey(SimEventType.Injury, e); break;
            case SimEventType.Offside: AddKey(SimEventType.Offside, e); break;
            case SimEventType.Corner:
                if (e.Team is 0 or 1) _corners[e.Team]++;
                AddKey(SimEventType.Corner, e);
                break;
            case SimEventType.FreeKick: AddKey(SimEventType.FreeKick, e); break;
            case SimEventType.PenaltyAwarded: AddKey(SimEventType.PenaltyAwarded, e); break;
            case SimEventType.PenaltyGoal:
            case SimEventType.PenaltyMiss:
                RegisterPen(e);
                break;
        }

        _st = SnapshotStats(e);

        string line = Narrate(e);
        if (!string.IsNullOrEmpty(line)) _ticker = line;
        if (e.Big || e.Type is SimEventType.HydrationBreak or SimEventType.HalfTime or SimEventType.ExtraTimeStart or SimEventType.ShootoutStart or SimEventType.FullTime or SimEventType.SecondHalf)
        { _banner = line; _bannerId++; }
        else _banner = null;
    }

    // Reconstruye el relato en el idioma activo a partir de los datos neutros del evento
    // (nombres y marcador no se traducen). Cae al Text español si el tipo no está mapeado.
    private string Narrate(SimEvent e)
    {
        string a = Short(e.Actor), tg = Short(e.Target);
        string F(string es, params object[] args) => string.Format(Loc[es], args);
        return e.Type switch
        {
            SimEventType.KickOff       => Loc["¡Comienza el partido!"],
            SimEventType.Foul          => F("Falta de {0} sobre {1}", a, tg),
            SimEventType.Yellow        => "🟨 " + F("Amarilla a {0}", a),
            SimEventType.Red           => "🟥 " + F("Roja a {0}", a),
            SimEventType.Corner        => "⛳ " + F("Corner. Lo tira {0}", a),
            SimEventType.FreeKick      => "🎯 " + F("Tiro libre. La pone {0}", a),
            SimEventType.FreeKickIndirect => "↗️ " + Loc["Tiro libre indirecto"],
            SimEventType.ThrowIn       => "↩️ " + Loc["Saque de banda"],
            SimEventType.Injury        => "🚑 " + F("{0} queda golpeado y necesita atención", a),
            SimEventType.Offside       => "🚩 " + F("Offside · posición adelantada de {0}", a),
            SimEventType.Shot          => F("Remate de {0} ({1})", a, e.Target),
            SimEventType.Goal          => "⚽ " + F("¡GOOOL de {0}!", a) + $"  ({e.ScoreH}-{e.ScoreA})",
            SimEventType.Save          => "🧤 " + F("¡Atajó {0}!", a),
            SimEventType.Post          => "😱 " + F("¡{0} al palo!", a),
            SimEventType.Miss          => F("Remate desviado de {0}", a),
            SimEventType.HydrationBreak=> "💧 " + F("Pausa de hidratación (min {0})", e.Actor),
            SimEventType.HalfTime      => "⏸ " + Loc["Entretiempo"] + $" · {e.ScoreH}-{e.ScoreA}",
            SimEventType.SecondHalf    => Loc["Arranca el segundo tiempo"],
            SimEventType.FullTime      => "⏱ " + (e.Phase == MatchPhase.ExtraSecond ? "120'" : Loc["Final del partido"]) + $" · {e.ScoreH}-{e.ScoreA}",
            SimEventType.ExtraTimeStart=> "⏳ " + Loc["¡Tiempo suplementario!"],
            SimEventType.ShootoutStart => "🎯 " + Loc["¡Definición por penales!"],
            SimEventType.PenaltyAwarded => "🎯 " + F("¡PENAL! Lo patea {0}", a),
            SimEventType.PenaltyGoal   => "✅ " + F("{0} anota", a) + $"  ({e.ScoreH}-{e.ScoreA})",
            SimEventType.PenaltyMiss   => "❌ " + F("{0} le ataja a {1}", a, tg) + $"  ({e.ScoreH}-{e.ScoreA})",
            _ => e.Text,
        };
    }

    /// <summary>
    /// En x4 o salteando, los eventos entran en ráfaga: silbatos, gritos y bocinas
    /// se pisan entre sí y aturden. En ese modo apagamos los efectos y el ambiente,
    /// y dejamos sólo la música de hinchada, que da la sensación de "esto va rápido".
    /// </summary>
    private bool Rapido => _skip || _speed <= 0.25;

    private void SetSpeed(double v)
    {
        _speed = v;
        AjustarSonido();
    }

    private void Saltar()
    {
        _skip = true;
        AjustarSonido();
    }

    private void AjustarSonido()
    {
        // No miramos _sonido acá: el mute ya lo respeta odoSfx del lado de JS, y
        // duplicar la condición sólo agrega una forma de que la música no arranque.
        if (_done) return;
        if (Rapido) { Sfx.CrowdStop(); Sfx.MusicStart(); }
        else { Sfx.MusicStop(); Sfx.CrowdStart(); }
    }

    /// <summary>Le pone sonido a lo que pasa en la cancha.</summary>
    private void Sonar(SimEvent e)
    {
        if (Rapido) return;   // en modo rápido manda la música, no los efectos

        switch (e.Type)
        {
            case SimEventType.KickOff:        Sfx.CrowdStart(); Sfx.Play("whistle"); break;
            case SimEventType.Goal:           Sfx.Play("goal"); break;
            case SimEventType.Yellow:         Sfx.Play("yellow"); break;
            case SimEventType.Red:            Sfx.Play("red"); Sfx.Play("boo"); break;
            case SimEventType.Offside:        Sfx.Play("whistle"); break;
            case SimEventType.Foul:           Sfx.Play("whistle"); break;
            case SimEventType.PenaltyAwarded: Sfx.Play("whistleLong"); Sfx.Play("boo"); break;
            case SimEventType.Save:           Sfx.Play("roar"); break;
            case SimEventType.Post:           Sfx.Play("boo"); break;
            case SimEventType.HalfTime:       Sfx.Play("whistleLong"); break;
            case SimEventType.SecondHalf:     Sfx.Play("whistle"); break;
            case SimEventType.FullTime:       Sfx.Play("whistleLong"); break;
            case SimEventType.ShootoutStart:  Sfx.Play("whistleLong"); break;
            case SimEventType.PenaltyGoal:    Sfx.Play("goal"); break;
            case SimEventType.PenaltyMiss:    Sfx.Play("boo"); break;
        }
    }

    private void AddKey(SimEventType type, SimEvent e)
    {
        string ico = type switch
        {
            SimEventType.Goal => "⚽",
            SimEventType.Yellow => "🟨",
            SimEventType.Red => "🟥",
            SimEventType.Injury => "🚑",
            SimEventType.Offside => "🚩",
            SimEventType.Corner => "⛳",
            SimEventType.FreeKick => "🎯",
            SimEventType.PenaltyAwarded => "🎯",
            _ => "•"
        };
        string side = e.Team == 0 ? "home" : "away";
        // texto localizado sin el emoji inicial (la columna ya muestra su propio icono)
        string txt = Narrate(e);
        int sp = txt.IndexOf(' ');
        if (sp > 0 && !char.IsLetter(txt[0]) && txt[0] != '¡') txt = txt[(sp + 1)..];
        _keyEvents.Insert(0, new KeyEv(DisplayMin(), ico, txt, side));
        if (_keyEvents.Count > 12) _keyEvents.RemoveAt(_keyEvents.Count - 1);
    }

    private void RegisterPen(SimEvent e)
    {
        bool scored = e.Type == SimEventType.PenaltyGoal;
        var list = e.Team == 0 ? _homePens : _awayPens;
        var takers = e.Team == 0 ? _homeTakers : _awayTakers;
        int kick = list.Count;
        list.Add(scored);
        _penScored = scored;
        _penTaker = takers.Count > 0 ? takers[kick % takers.Count] : (e.Team == 0 ? HomeName : AwayName);

        string side = _rng.Next(2) == 0 ? "l" : "r";
        if (scored)
        {
            _penBallClass = "in-" + side;
            // el arquero suele volar al lado equivocado
            _penKeeperClass = "dive-" + (_rng.Next(3) == 0 ? side : (side == "l" ? "r" : "l"));
        }
        else
        {
            // atajada: el arquero vuela al mismo lado y la frena
            _penBallClass = "save-" + side;
            _penKeeperClass = "dive-" + side;
        }
        _penKickId++;
        UpdatePens(e.Text);
    }

    private MatchStats SnapshotStats(SimEvent e)
    {
        double prog = Math.Clamp(_clockSec / (double)(94 * 60), 0, 1);
        var f = Timeline.Stats;
        int S(int v) => (int)Math.Round(v * Math.Max(prog, 0.02));
        int totPoss = _possCount[0] + _possCount[1];
        int poss = totPoss < 6 ? 50 : (int)Math.Round(100.0 * _possCount[0] / totPoss);
        return new MatchStats
        {
            PossHome = poss,
            ShotsHome = S(f.ShotsHome), ShotsAway = S(f.ShotsAway),
            FoulsHome = S(f.FoulsHome), FoulsAway = S(f.FoulsAway),
            YellowHome = S(f.YellowHome), YellowAway = S(f.YellowAway),
            RedHome = S(f.RedHome), RedAway = S(f.RedAway),
            // Los corners se cuentan de VERDAD, uno por uno, en vez de estimarlos
            // por el avance del reloj: ahora son jugadas que se ven en la cancha,
            // y el numero tiene que coincidir con lo que acabas de mirar.
            CornersHome = _corners[0], CornersAway = _corners[1],
        };
    }

    private void UpdatePens(string text)
    {
        int i = text.LastIndexOf('('), j = text.LastIndexOf(')');
        if (i >= 0 && j > i) _pens = text.Substring(i + 1, j - i - 1);
    }

    /// <summary>
    /// Arma a los 22 para una jugada detenida. Devuelve false si el evento no es
    /// una de ellas y hay que usar el seguimiento normal.
    ///
    /// Equipo 0 ataca hacia la DERECHA (su arco esta en x pequeno) y el 1 al reves.
    /// Todo se acota a la cancha para que no se corten los nombres.
    /// </summary>
    private bool JugadaDetenida(SimEvent e)
    {
        if (e.Team is not (0 or 1)) return false;
        if (e.Type is not (SimEventType.Corner or SimEventType.ThrowIn or SimEventType.PenaltyAwarded
                           or SimEventType.FreeKick or SimEventType.FreeKickIndirect))
            return false;

        int at = e.Team, df = 1 - at;               // ataca / defiende
        double dir = at == 0 ? 1 : -1;              // hacia donde ataca
        double arcoRival = at == 0 ? 0.955 : 0.045; // arco al que le tira
        double arcoPropio = at == 0 ? 0.045 : 0.955;

        var ax = at == 0 ? _hx : _ax; var ay = at == 0 ? _hy : _ay;
        var dx = df == 0 ? _hx : _ax; var dy = df == 0 ? _hy : _ay;

        void Poner(double[] X, double[] Y, int i, double x, double y)
        {
            X[i] = Math.Clamp(x, 0.06, 0.94);
            Y[i] = Math.Clamp(y, 0.08, 0.92);
        }

        // Los arqueros van SIEMPRE a su arco
        Poner(ax, ay, 0, arcoPropio, 0.5);
        Poner(dx, dy, 0, arcoRival, 0.5);

        if (e.Type == SimEventType.PenaltyAwarded)
        {
            // La foto del penal: el pateador solo con la pelota, el arquero en la
            // linea y TODOS los demas afuera del area, en semicirculo.
            Poner(ax, ay, 1, e.BallX - dir * 0.045, 0.5);          // el que patea
            Poner(dx, dy, 0, arcoRival + dir * 0.012, 0.5);        // arquero en la raya

            double borde = at == 0 ? 0.70 : 0.30;                  // limite del area
            for (int i = 2; i < 11; i++)                           // companeros afuera
            {
                double ang = (i - 2) / 8.0 * Math.PI - Math.PI / 2;
                Poner(ax, ay, i, borde - dir * 0.05 * Math.Cos(ang), 0.5 + 0.30 * Math.Sin(ang));
            }
            for (int i = 1; i < 11; i++)                           // rivales afuera
            {
                double ang = (i - 1) / 9.0 * Math.PI - Math.PI / 2;
                Poner(dx, dy, i, borde + dir * 0.02 * Math.Cos(ang), 0.5 + 0.34 * Math.Sin(ang));
            }
            return true;
        }

        if (e.Type is SimEventType.FreeKick or SimEventType.FreeKickIndirect)
        {
            // La BARRERA es lo que hace que un tiro libre se vea como tal: cuatro
            // defensores hombro con hombro a nueve metros, tapando el arco.
            Poner(ax, ay, 1, e.BallX - dir * 0.035, e.BallY);            // el que patea

            double haciaArco = Math.Atan2(0.5 - e.BallY, arcoRival - e.BallX);
            double bx = e.BallX + Math.Cos(haciaArco) * 0.10;
            double by = e.BallY + Math.Sin(haciaArco) * 0.10;
            double perpX = -Math.Sin(haciaArco), perpY = Math.Cos(haciaArco);

            for (int i = 1; i <= 4; i++)                                  // la barrera
            {
                double off = (i - 2.5) * 0.035;
                Poner(dx, dy, i, bx + perpX * off, by + perpY * off);
            }
            Poner(dx, dy, 0, arcoRival, 0.5);                             // arquero al medio

            // El resto de la defensa marca dentro del area
            for (int i = 5; i < 11; i++)
            {
                double k = (i - 5) / 5.0;
                Poner(dx, dy, i, arcoRival - dir * (0.10 + k * 0.05), 0.28 + k * 0.44);
            }
            // Los atacantes esperan el centro / el rebote
            for (int i = 2; i <= 7; i++)
            {
                double k = (i - 2) / 5.0;
                Poner(ax, ay, i, arcoRival - dir * (0.17 - k * 0.05), 0.30 + k * 0.40);
            }
            for (int i = 8; i < 11; i++)
                Poner(ax, ay, i, 0.5 - dir * 0.08, 0.30 + (i - 8) * 0.20);
            return true;
        }

        if (e.Type == SimEventType.Corner)
        {
            bool arriba = e.BallY < 0.5;
            double haciaCentro = arriba ? 1 : -1;

            Poner(ax, ay, 1, e.BallX - dir * 0.02, e.BallY + haciaCentro * 0.03);   // el que lo tira

            // Seis atacantes se meten al area, escalonados
            for (int i = 2; i <= 7; i++)
            {
                double k = (i - 2) / 5.0;
                Poner(ax, ay, i, arcoRival - dir * (0.13 - k * 0.07), 0.30 + k * 0.40);
            }
            // Tres se quedan afuera por si sale el contragolpe
            for (int i = 8; i < 11; i++)
                Poner(ax, ay, i, 0.5 - dir * 0.06, 0.28 + (i - 8) * 0.22);

            // La defensa se mete toda al area a marcar
            for (int i = 1; i <= 8; i++)
            {
                double k = (i - 1) / 7.0;
                Poner(dx, dy, i, arcoRival - dir * (0.10 - k * 0.06), 0.27 + k * 0.46);
            }
            for (int i = 9; i < 11; i++)                            // dos aguantan afuera
                Poner(dx, dy, i, arcoRival - dir * 0.26, 0.36 + (i - 9) * 0.28);
            return true;
        }

        // Saque de banda: el que saca sobre la raya y el resto se abre a recibir
        bool arribaL = e.BallY < 0.5;
        double dentro = arribaL ? 1 : -1;
        Poner(ax, ay, 1, e.BallX, e.BallY + dentro * 0.02);        // el que saca

        for (int i = 2; i <= 4; i++)                                // se ofrecen cerca
            Poner(ax, ay, i, e.BallX + dir * (i - 2) * 0.10 - dir * 0.05,
                             e.BallY + dentro * (0.10 + (i - 2) * 0.07));
        for (int i = 5; i < 11; i++)                                // el resto mantiene forma
        {
            var b = at == 0 ? _homeBase : _awayBase;
            Poner(ax, ay, i, b[i].x + (e.BallX - b[i].x) * 0.25, b[i].y + (e.BallY - b[i].y) * 0.15);
        }
        for (int i = 1; i <= 3; i++)                                // marcan a los que reciben
            Poner(dx, dy, i, e.BallX + dir * (i - 1) * 0.10 - dir * 0.02,
                             e.BallY + dentro * (0.15 + (i - 1) * 0.07));
        for (int i = 4; i < 11; i++)
        {
            var b = df == 0 ? _homeBase : _awayBase;
            Poner(dx, dy, i, b[i].x + (e.BallX - b[i].x) * 0.15, b[i].y + (e.BallY - b[i].y) * 0.10);
        }
        return true;
    }

    private (double x, double y)[] BasePositions(Formation f, bool home)
    {
        double[] xl = home ? new[] { 0.10, 0.25, 0.42, 0.60 } : new[] { 0.90, 0.75, 0.58, 0.40 };
        var res = new List<(double, double)>();
        var lines = new[] { (0, 1), (1, f.Def), (2, f.Mid), (3, f.Fwd) };
        foreach (var (li, count) in lines)
            for (int i = 0; i < count; i++)
            {
                double y = 0.14 + (i + 1) / (double)(count + 1) * 0.72;
                res.Add((xl[li], y));
            }
        while (res.Count < 11) res.Add((0.5, 0.5));
        return res.Take(11).ToArray();
    }

    private static string NameAt(IReadOnlyList<Player>? sq, int i)
        => sq is not null && i < sq.Count ? Short(sq[i].Name) : "";

    private static List<string> Takers(IReadOnlyList<Player>? sq, string fallback)
    {
        if (sq is null || sq.Count == 0) return new() { fallback };
        return sq.OrderByDescending(p => p.Pos == Position.FWD ? 3 : p.Pos == Position.MID ? 2 : p.Pos == Position.DEF ? 1 : 0)
                 .ThenByDescending(p => p.Rating)
                 .Select(p => Short(p.Name)).ToList();
    }

    // ---- Reloj estilo TV: 45+X, 90+X ----
    private int DisplayMin()
    {
        int m = Math.Max(1, _clockSec / 60 + (_clockSec % 60 > 0 ? 1 : 0));
        return m;
    }

    private string ClockLabel
    {
        get
        {
            int m = DisplayMin();
            return _phase switch
            {
                MatchPhase.First => m <= 45 ? $"{m}'" : $"45+{m - 45}'",
                MatchPhase.Half => "ENT",
                MatchPhase.Second => m <= 90 ? $"{m}'" : $"90+{m - 90}'",
                MatchPhase.ExtraFirst => m <= 105 ? $"{m}'" : $"105+{m - 105}'",
                MatchPhase.ExtraSecond => m <= 120 ? $"{m}'" : $"120+{m - 120}'",
                MatchPhase.Shootout => "PEN",
                _ => $"{m}'"
            };
        }
    }

    private string PhaseLabel => Loc[_phase switch
    {
        MatchPhase.First => "1º TIEMPO",
        MatchPhase.Half => "ENTRETIEMPO",
        MatchPhase.Second => "2º TIEMPO",
        MatchPhase.ExtraFirst => "PRÓRROGA 1",
        MatchPhase.ExtraSecond => "PRÓRROGA 2",
        MatchPhase.Shootout => "TANDA DE PENALES",
        _ => "FINAL"
    }];

    private static string Pct(double v) => (v * 100).ToString("0.##", System.Globalization.CultureInfo.InvariantCulture) + "%";
    private static string Short(string s)
    {
        // Igual que en Equipo: sin esto, "Pele (Prime 1970)" salia a la cancha
        // como "1970)".
        s = PrimeDatabase.BaseName(s);
        var parts = s.Split(' ');
        var name = parts.Length == 1 ? s : parts[^1];
        return name.Length <= 12 ? name : name[..12];
    }
}
