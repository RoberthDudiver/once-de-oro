@page "/mercado"
@inherits GamePageBase
@inject Sfx Sfx

<PageTitle>Mercado — Once de Oro</PageTitle>

<div class="section-title"><span class="dot"></span> @Loc["Mercado de fichajes"]</div>

<div class="row wrap" style="justify-content:space-between; gap:14px;">
    <div class="seg">
        <button class="@(Tab == "buy" ? "on" : "")" @onclick='() => Tab = "buy"'>@Loc["💰 Comprar"]</button>
        <button class="@(Tab == "own" ? "on" : "")" @onclick='() => Tab = "own"'>@Loc["👕 Mi plantel"] (@Game.Owned.Count())</button>
        <button class="@(Tab == "box" ? "on" : "")" @onclick='() => Tab = "box"'>@Loc["🎁 Cajas"]</button>
        <button class="@(Tab == "all" ? "on" : "")" @onclick='() => Tab = "all"'>@Loc["📖 Catálogo"]</button>
        <button class="@(Tab == "stad" ? "on" : "")" @onclick='() => Tab = "stad"'>@Loc["🏟️ Estadio"]</button>
    </div>
    <div class="seg">
        <button class="@(Pos is null ? "on" : "")" @onclick="() => Pos = null">@Loc["Todos"]</button>
        <button class="@(Pos == Position.GK ? "on" : "")" @onclick="() => Pos = Position.GK">POR</button>
        <button class="@(Pos == Position.DEF ? "on" : "")" @onclick="() => Pos = Position.DEF">DEF</button>
        <button class="@(Pos == Position.MID ? "on" : "")" @onclick="() => Pos = Position.MID">MED</button>
        <button class="@(Pos == Position.FWD ? "on" : "")" @onclick="() => Pos = Position.FWD">DEL</button>
    </div>
</div>

@if (Tab == "box")
{
    <div class="faint mb" style="font-size:12.5px;">
        @Loc["Pagás, tirás la moneda y sale lo que sale. Ojo: lo que salga de una caja se revende a precio de saldo, así que no es negocio abrirlas para vender."]
    </div>

    @* ---------------- El rodillo: gira, frena y cae en el premio ---------------- *@
    @if (_tira.Count > 0)
    {
        <div class="case @(_premio is not null ? "case--done " + Rare(_premio) : "")">
            <div class="case__title">
                @if (_girando) { <span>@Loc["Girando…"]</span> }
                else if (_premio is not null)
                {
                    @if (_premio.Troll) { <span>🤡 @Loc["¡GARANTIZADO!"] 🤡</span> }
                    else if (_premio.Rating >= 100) { <span>🔥 @Loc["¡FUERA DE ESCALA!"] 🔥</span> }
                    else if (_premio.Rating >= 99) { <span>✨ @Loc["¡SE ROMPIÓ LA CAJA!"] ✨</span> }
                    else { <span>@Loc["Salió de la caja"]</span> }
                }
            </div>

            <div class="case__window">
                <div class="case__needle"></div>
                <div class="case__strip" style="transform:translateX(-@(_offset)px); transition-duration:@(_girando ? SpinMs : 0)ms;">
                    @foreach (var (p, i) in _tira.Select((p, i) => (p, i)))
                    {
                        <div class="case__item @Rare(p) @(!_girando && i == PremioIdx ? "case__item--win" : "")">
                            <span class="case__rat">@p.Rating</span>
                            <span class="case__pos">@p.Pos.Label()</span>
                        </div>
                    }
                </div>
                <div class="case__fade case__fade--l"></div>
                <div class="case__fade case__fade--r"></div>
            </div>

            @if (_premio is not null)
            {
                <div class="case__prize">
                    <PlayerCard P="_premio" ShowPrice="false" OnOpen="Abrir" />
                    @if (_premio.Troll)
                    {
                        <div class="loot-reveal__joke">@Loc["Un 110 de verdad. Lástima que juegue como un 45."]</div>
                    }
                    <button class="btn btn--ghost mt" @onclick="Cerrar">@Loc["Listo"]</button>
                </div>
            }
        </div>
    }

    <div class="grid" style="gap:12px;">
        @foreach (var caja in GameService.LootBoxes)
        {
            var payaso = caja.Key == GameService.ClownBox;
            <div class="lootbox @(payaso ? "lootbox--troll" : "")">
                <div class="lootbox__ico">@caja.Emoji</div>
                <div class="lootbox__body">
                    <div class="lootbox__name">@Loc[caja.Name]</div>
                    <div class="lootbox__desc">@Loc[caja.Desc]</div>
                    <div class="lootbox__odds">
                        @foreach (var b in caja.Bands)
                        {
                            <span class="odd" title="@Odds(caja, b)">
                                <b>@(b.Min == b.Max ? $"{b.Min}" : $"{b.Min}–{b.Max}")</b> @Odds(caja, b)
                            </span>
                        }
                    </div>
                </div>
                <button class="btn btn--gold lootbox__btn"
                        disabled="@(_girando || !Game.CanOpenBox(caja))"
                        @onclick="() => Abrir(caja)">
                    @Loc["Abrir"] · $@caja.Cost M
                </button>
            </div>
        }
    </div>
}
else if (Tab == "stad")
{
    var actual = Game.Stadium;
    <div class="faint mb" style="font-size:12.5px;">
        @Loc["Cuanta más gente entra al estadio, más se recauda en cada partido. La entrada se cobra sola al terminar el partido."]
    </div>

    <div class="card card--pad mb">
        <div class="row wrap" style="justify-content:space-between; gap:12px;">
            <div>
                <div class="muted" style="font-size:12px; letter-spacing:.2em; text-transform:uppercase;">@Loc["Tu estadio"]</div>
                <div style="font-family:var(--font-head); font-size:22px; color:var(--gold-2);">@Loc[actual.Name]</div>
            </div>
            <div class="row wrap" style="gap:8px;">
                <span class="pill">👥 @actual.Capacity.ToString("N0")</span>
                <span class="pill pill--gold">💰 @Plata(actual.IncomeK) @Loc["por partido"]</span>
            </div>
        </div>
    </div>

    <div class="grid" style="gap:10px;">
        @foreach (var t in GameService.StadiumTiers)
        {
            var tengo = Game.OwnsStadium(t);
            <div class="lootbox @(t.Key == actual.Key ? "lootbox--troll" : "")">
                <div class="lootbox__ico">🏟️</div>
                <div class="lootbox__body">
                    <div class="lootbox__name">@Loc[t.Name]</div>
                    <div class="lootbox__desc">@Loc[t.Desc]</div>
                    <div class="lootbox__odds">
                        <span class="odd"><b>👥 @t.Capacity.ToString("N0")</b></span>
                        <span class="odd"><b>💰 @Plata(t.IncomeK)</b> @Loc["por partido"]</span>
                    </div>
                </div>
                @if (t.Key == actual.Key)
                {
                    <span class="pill pill--gold" style="white-space:nowrap;">✓ @Loc["El tuyo"]</span>
                }
                else if (tengo)
                {
                    <span class="pill" style="white-space:nowrap;">@Loc["Superado"]</span>
                }
                else
                {
                    <button class="btn btn--gold lootbox__btn"
                            disabled="@(!Game.CanBuyStadium(t))"
                            @onclick="() => Game.BuyStadium(t)">
                        @Loc["Comprar"] · $@t.Cost M
                    </button>
                }
            </div>
        }
    </div>
}
else
{
<input class="search" placeholder="@Loc["🔎 Buscar jugador o selección…"]" @bind="Search" @bind:event="oninput" />

<div class="row wrap mb" style="gap:10px;">
    <select class="mkt-select" @bind="Country">
        <option value="">@Loc["🌍 Todos los países"]</option>
        @foreach (var n in Countries)
        {
            <option value="@n">@n</option>
        }
    </select>
    <select class="mkt-select" @bind="Decade">
        <option value="0">@Loc["📅 Todas las épocas"]</option>
        @foreach (var d in Decades)
        {
            <option value="@d">@d — @(d + 9)</option>
        }
    </select>
    @if (!string.IsNullOrEmpty(Country) || Decade != 0 || Pos is not null || !string.IsNullOrWhiteSpace(Search))
    {
        <button class="btn btn--ghost" style="padding:10px 16px;" @onclick="ClearFilters">@Loc["✕ Limpiar"]</button>
    }
</div>

@if (Tab == "all")
{
    <div class="faint mb" style="font-size:12.5px;">
        @Loc["Todos los jugadores que existen, tengas o no. Los de 100+ son versiones PRIME: no se compran, solo salen de las cajas."]
        · <b>@Lista().Count</b> / @(PlayerDatabase.All.Count + PrimeDatabase.All.Count)
    </div>
}

@if (Lista().Count == 0)
{
    <div class="empty">
        <div class="empty__ico">@(Tab == "own" ? "👕" : "🔍")</div>
        <p>@(Tab == "own" ? Loc["Tu plantel está vacío. Andá a Comprar para fichar."] : Loc["No hay jugadores con ese filtro."])</p>
    </div>
}
else
{
    <div class="grid grid--cards">
        @foreach (var p in Lista().Take(_verHasta))
        {
            <PlayerCard P="p" ShowPrice="@(Tab != "all")"
                        Price="@(Tab == "buy" ? Game.BuyPrice(p) : Game.SellPrice(p))" OnOpen="Abrir">
                <Actions>
                    @if (Tab == "all")
                    {
                        @* En el catálogo no se compra ni se vende: se mira. Lo único que
                           agrega es si ya lo tenés y cuánto sale. *@
                        @if (p.Rating >= 100)
                        {
                            @* Prime: no se vende, sólo sale de una caja. *@
                            @if (MisNombres().Contains(p.Name))
                            {
                                <span class="pill pill--gold" style="white-space:nowrap;">✓ @Loc["Lo tenés"]</span>
                            }
                            else
                            {
                                <span class="pill" style="white-space:nowrap; color:var(--blue); border-color:rgba(78,163,255,.45);">
                                    🎁 @Loc["Solo por caja"]
                                </span>
                            }
                        }
                        else if (Game.Owns(p.Id))
                        {
                            <span class="pill pill--gold" style="white-space:nowrap;">✓ @Loc["Lo tenés"]</span>
                        }
                        else
                        {
                            <span class="pill" style="white-space:nowrap;">$@Game.BuyPrice(p) M</span>
                        }
                    }
                    else if (Tab == "buy")
                    {
                        <button class="icon-btn icon-btn--buy" title="Fichar por @Game.BuyPrice(p) M"
                                disabled="@(Game.State.Money < Game.BuyPrice(p))"
                                @onclick="() => Game.Buy(p.Id)">＋</button>
                    }
                    else
                    {
                        <button class="icon-btn icon-btn--sell" title="Vender por @Game.SellPrice(p) M"
                                @onclick="() => Game.Sell(p.Id)">✕</button>
                    }
                </Actions>
            </PlayerCard>
        }
    </div>

    @if (Lista().Count > _verHasta)
    {
        <div class="center mt">
            <button class="btn btn--ghost" @onclick="() => _verHasta += Pagina">
                @Loc["Ver más"] (@(Lista().Count - _verHasta))
            </button>
        </div>
    }
}
}

<PlayerDetail P="_ficha" OnClose="() => _ficha = null" />

@code {
    private Player? _ficha;
    private void Abrir(Player p) => _ficha = p;

    // Los primes se reconocen por NOMBRE (el que tenés salió de una caja y su Id es
    // otro). Se arma el conjunto una vez por dibujo: Game.Owned resuelve cada id
    // contra todo el plantel y llamarlo una vez por carta se nota.
    private HashSet<string>? _misNombres;
    private HashSet<string> MisNombres() => _misNombres ??= Game.Owned.Select(p => p.Name).ToHashSet();
    protected override void OnGameChanged() => _misNombres = null;

    /// <summary>Formatea la recaudación: "500 mil" o "200 M".</summary>
    private static string Plata(int miles) =>
        miles < 1000 ? $"{miles} mil" : $"{miles / 1000} M";

    /// <summary>Los jugadores que se ven con los filtros puestos.</summary>
    private List<Player> Lista() =>
        (Tab switch
        {
            "buy" => Game.Market,             // los que podés fichar ahora
            "own" => Game.Owned,              // tu plantel
            // Catálogo: todo lo que existe, incluidas las versiones prime que NO
            // están en venta (para que se vea qué se puede cazar con las cajas).
            _ => PlayerDatabase.All.Concat(PrimeDatabase.All),
        })
            .Where(p => Pos is null || p.Pos == Pos)
            .Where(p => string.IsNullOrEmpty(Country) || p.Nation == Country)
            .Where(p => Decade == 0 || p.Era / 10 * 10 == Decade)
            .Where(p => string.IsNullOrWhiteSpace(Search)
                     || p.Name.Contains(Search, StringComparison.OrdinalIgnoreCase)
                     || p.Nation.Contains(Search, StringComparison.OrdinalIgnoreCase))
            .OrderByDescending(p => p.Rating)
            .ToList();

    // ---- El rodillo de casino ----
    // El premio ya está decidido ANTES de que empiece a girar (lo sortea OpenBox):
    // la animación no decide nada, sólo lo cuenta. Por eso se arma una tira larga
    // con el ganador clavado en una posición fija y se desplaza hasta ahí.

    private const int SpinMs = 4600;      // lo que dura el giro
    private const int ItemW = 104;        // 96 del casillero + 8 de separación (fijado en app.css)
    private const int PremioIdx = 42;     // dónde va el ganador dentro de la tira
    private const int TiraLargo = 48;

    private List<Player> _tira = new();
    private Player? _premio;
    private bool _girando;
    private int _offset;

    private async Task Abrir(GameService.LootBox caja)
    {
        if (_girando) return;

        var p = Game.OpenBox(caja);
        if (p is null) return;

        _premio = null;
        _tira = ArmarTira(caja, p);

        // Primer pintado con la tira en cero y SIN transición: si no, el navegador
        // no tiene un estado inicial desde el cual animar y el rodillo aparece
        // directamente en el premio.
        _girando = false;
        _offset = 0;
        StateHasChanged();
        await Task.Delay(60);

        // Ahora sí: se prende la transición y se manda al premio.
        _girando = true;
        // Un desvío chico para que no frene siempre clavado en el centro.
        _offset = PremioIdx * ItemW + ItemW / 2 + Random.Shared.Next(-28, 29);
        Sfx.Reel(SpinMs);
        StateHasChanged();

        await Task.Delay(SpinMs + 120);
        _girando = false;
        _premio = p;
        Sfx.Play(p.Troll ? "fail" : p.Rating >= 99 ? "jackpot" : p.Rating >= 90 ? "goal" : "whistle");
        StateHasChanged();
    }

    private void Cerrar()
    {
        _premio = null;
        _tira = new();
    }

    /// <summary>
    /// La tira que se ve girando: relleno sorteado con las MISMAS probabilidades
    /// de la caja (así lo que desfila es creíble para esa caja) y el ganador real
    /// clavado en su posición.
    /// </summary>
    private static List<Player> ArmarTira(GameService.LootBox caja, Player premio)
    {
        var tira = new List<Player>();
        for (int i = 0; i < TiraLargo; i++)
        {
            if (i == PremioIdx) { tira.Add(premio); continue; }
            tira.Add(Falso(caja, i));
        }
        return tira;
    }

    /// <summary>Un casillero de relleno: sólo se le ven la fuerza y el puesto.</summary>
    private static Player Falso(GameService.LootBox caja, int i)
    {
        double tiro = Random.Shared.NextDouble() * caja.Total, acum = 0;
        var band = caja.Bands[^1];
        foreach (var b in caja.Bands)
        {
            acum += b.Weight;
            if (tiro <= acum) { band = b; break; }
        }
        return new Player
        {
            Id = $"spin-{i}", Name = "", Nation = "", Flag = "",
            Pos = (Position)Random.Shared.Next(4),
            Rating = Random.Shared.Next(band.Min, band.Max + 1),
        };
    }

    /// <summary>Color del casillero según lo que salió. Es todo el golpe de efecto.</summary>
    private static string Rare(Player p) =>
        p.Troll ? "r-troll"
        : p.Rating >= 100 ? "r-myth"
        : p.Rating >= 99 ? "r-gold"
        : p.Rating >= 90 ? "r-epic"
        : p.Rating >= 80 ? "r-rare"
        : p.Rating >= 70 ? "r-good"
        : "r-comun";

    /// <summary>Probabilidad del tramo, redondeada sin achatar las chances chicas.</summary>
    private static string Odds(GameService.LootBox caja, GameService.LootBand b)
    {
        double pc = caja.ChanceOf(b);
        return pc >= 10 ? $"{pc:0}%" : pc >= 1 ? $"{pc:0.0}%" : $"{pc:0.00}%";
    }

    // El catálogo son 442 cartas: dibujarlas todas de una hace una página de 20.000px
    // que en un teléfono se arrastra. Se muestran de a tandas.
    private const int Pagina = 60;
    private int _verHasta = Pagina;

    private string Tab
    {
        get => _tab;
        set { _tab = value; _verHasta = Pagina; }   // cambiar de pestaña empieza de nuevo
    }
    private string _tab = "buy";

    // Cada filtro vuelve a la primera tanda: si no, filtrás y seguís viendo el
    // botón "Ver más" de la búsqueda anterior.
    private Position? Pos { get => _pos; set { _pos = value; _verHasta = Pagina; } }
    private Position? _pos;

    private string Search { get => _search; set { _search = value; _verHasta = Pagina; } }
    private string _search = "";

    private string Country { get => _country; set { _country = value; _verHasta = Pagina; } }
    private string _country = "";

    private int Decade { get => _decade; set { _decade = value; _verHasta = Pagina; } }
    private int _decade;

    private static readonly List<string> Countries =
        PlayerDatabase.All.Select(p => p.Nation).Distinct().OrderBy(n => n).ToList();
    private static readonly List<int> Decades =
        PlayerDatabase.All.Select(p => p.Era / 10 * 10).Distinct().OrderByDescending(d => d).ToList();

    private void ClearFilters() { Country = ""; Decade = 0; Pos = null; Search = ""; }
}
