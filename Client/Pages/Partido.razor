@page "/partido"
@inherits GamePageBase
@inject NavigationManager Nav
@inject Sfx Sfx

<PageTitle>Partido — Once de Oro</PageTitle>

@if (Game.State.Run is null || Game.ActiveComp is null)
{
    <div class="empty">
        <div class="empty__ico">🏟️</div>
        <p>@Loc["No hay ningún torneo en curso."]</p>
        <button class="btn btn--gold mt" @onclick='() => Nav.NavigateTo("torneos")'>@Loc["Elegir torneo"]</button>
    </div>
}
else
{
    var comp = Game.ActiveComp!;
    var run = Game.State.Run!;
    var info = Game.StageInfo();
    var opp = Game.CurrentOpponent;

    @if (_phase == Phase.Pre && opp is not null)
    {
        var pw = Game.Power;
        var pred = Game.PredictNext();
        <div class="board fade-up">
            <div class="board__comp">@comp.Emblem @Loc[comp.Name]</div>
            <div class="board__stage">@info.stageName · @Loc["PREVIA"]</div>
            <div class="board__main">
                <div class="board__team">
                    <div class="board__flag">⚽</div>
                    <div class="board__tname">@Game.State.ClubName</div>
                </div>
                <div class="board__score" style="font-size:34px;">
                    <span style="color:var(--gold-2)">@pw.Overall</span>
                    <span class="sep">vs</span>
                    <span style="color:var(--blue)">@opp.Strength</span>
                </div>
                <div class="board__team">
                    <div class="board__flag">@opp.Flag</div>
                    <div class="board__tname">@opp.Name</div>
                </div>
            </div>
        </div>

        <div class="card card--pad mt">
            <div class="row" style="justify-content:space-between;">
                <h3 style="font-size:19px;">@Loc["📊 Pronóstico"]</h3>
                <span class="pill">Poisson + Elo</span>
            </div>
            <div class="tri mt">
                <div class="tri__seg win" style="width:@Pc(pred.HomeWin)"><span>@Pc(pred.HomeWin)</span></div>
                <div class="tri__seg draw" style="width:@Pc(pred.Draw)"><span>@Pc(pred.Draw)</span></div>
                <div class="tri__seg lose" style="width:@Pc(pred.AwayWin)"><span>@Pc(pred.AwayWin)</span></div>
            </div>
            <div class="tri__legend">
                <span><i class="d win"></i> @Loc["Ganás"]</span>
                <span><i class="d draw"></i> @Loc["Empate"]</span>
                <span><i class="d lose"></i> @Loc["Perdés"]</span>
            </div>
            <div class="row wrap mt" style="gap:8px;">
                <span class="pill pill--gold">xG @pred.XgHome.ToString("0.0")</span>
                <span class="pill">@Loc["goles esperados"]</span>
                <span class="pill" style="color:var(--blue);border-color:rgba(78,163,255,.4)">xG @pred.XgAway.ToString("0.0")</span>
            </div>
            <div class="row wrap mt" style="gap:8px;">
                <span class="pill">Elo @pred.EloHome</span>
                <span class="pill">@Loc["favoritismo"] @Pc(pred.EloHomeWin)</span>
                <span class="pill" style="color:var(--blue);border-color:rgba(78,163,255,.4)">Elo @pred.EloAway</span>
            </div>
            <div class="mt muted" style="font-size:13px;">
                @Loc["Marcadores más probables:"]
                @foreach (var s in pred.TopScores)
                {
                    <span class="pill" style="margin:2px 4px 2px 0;">@s.H–@s.A · @Pc(s.P)</span>
                }
            </div>
        </div>

        var lesionadosXI = Game.Starters.Where(p => Game.IsOut(p.Id)).ToList();
        <div class="card card--pad mt">
            <div class="row" style="justify-content:space-between; align-items:center;">
                <h3 style="font-size:18px;">🔄 @Loc["Ajustar el equipo"]</h3>
            </div>
            @if (lesionadosXI.Count > 0)
            {
                <div class="clash mt">
                    <div class="clash__txt">
                        🚑 @Loc["Tenés en el XI a"] <b>@string.Join(", ", lesionadosXI.Select(p => Short(p.Name)))</b>
                        @Loc["que no puede(n) jugar. Cambialo(s) antes de arrancar."]
                    </div>
                </div>
                <div class="row wrap mt" style="gap:8px;">
                    @foreach (var h in lesionadosXI)
                    {
                        <button class="btn btn--ghost" @onclick="() => Game.ReemplazarPorCantera(h.Id)">
                            🎓 @Loc["Que entre un juvenil por"] @Short(h.Name)
                        </button>
                    }
                </div>
            }
            @PanelCambio(previa: true)
        </div>

        <div class="center mt">
            <button class="btn btn--gold btn--big"
                    disabled="@(lesionadosXI.Count > 0)"
                    @onclick="Play">@Loc["▶ Ver el partido"]</button>
        </div>
    }
    else if (_phase == Phase.Playing && _timeline is not null && opp is not null)
    {
        <div class="match-stage" id="matchStage">
        @if (_vestuario)
        {
            @* ---------- ENTRETIEMPO: el momento del DT (capa sobre el estadio) ---------- *@
            var heridos = LesionadosObligatorios();
            <div class="vest-overlay">
            <div class="card card--pad vest">
                <div class="vest__ttl">🧴 @Loc["Entretiempo"] · @_result0</div>
                <div class="faint" style="font-size:12px; margin-top:2px;">@Loc["El partido está en pausa. Ajustá y salí al segundo tiempo."]</div>

                <div class="muted mt" style="font-size:12px; letter-spacing:.2em; text-transform:uppercase;">@Loc["Planteo"]</div>
                <div class="seg wrap mt">
                    @foreach (var st in Enum.GetValues<TeamStyle>())
                    {
                        <button class="@(Game.State.Style == st ? "on" : "")"
                                @onclick="() => Game.SetStyleSegundoTiempo(st)">@Loc[st.ToString()]</button>
                    }
                </div>
                <div class="faint mt" style="font-size:12px;">
                    @Loc["Ir al ataque cansa más a tus jugadores; meterse atrás, menos."]
                </div>

                @if (heridos.Count > 0)
                {
                    <div class="clash mt">
                        <div class="clash__txt">
                            🚑 @Loc["Se lesionó"] <b>@string.Join(", ", heridos.Select(p => Short(p.Name)))</b>.
                            @Loc["Cambialo(s) por un suplente, o que entre un juvenil."]
                        </div>
                    </div>
                    <div class="row wrap mt" style="gap:8px;">
                        @foreach (var h in heridos)
                        {
                            <button class="btn btn--ghost" @onclick="() => Game.ReemplazarPorCantera(h.Id)">
                                🎓 @Loc["Que entre un juvenil por"] @Short(h.Name)
                            </button>
                        }
                    </div>
                }

                <div class="muted mt" style="font-size:12px; letter-spacing:.2em; text-transform:uppercase;">
                    @Loc["Cambios"] · @Game.CambiosDisponibles @Loc["disponibles"]
                </div>
                @PanelCambio(previa: false)

                <button class="btn btn--gold btn--block mt"
                        disabled="@(heridos.Count > 0)"
                        @onclick="SalirAlSegundoTiempo">
                    ▶ @Loc["Salir al segundo tiempo"]
                </button>
            </div>
            </div>
        }

        <MatchField @ref="_campo" PararEnEntretiempo="true" OnEntretiempo="AbrirVestuario"
                    Timeline="_timeline"
                    HomeName="@Game.State.ClubName" HomeFlag="⚽" HomeFormationName="@Game.Formation.Name"
                    AwayName="@opp.Name" AwayFlag="@opp.Flag"
                    HomeStarters="Game.LastHomeStarters" AwayStarters="Game.LastAwaySquad"
                    Round="@($"{comp.Emblem} {Loc[comp.Name]} · {_stageLabel}")"
                    OnFinished="OnMatchFinished" />
        </div>
    }
    else if (_phase == Phase.Done)
    {
        @if (_result is not null)
        {
            var win = _result.HomeWon;
            var draw = !_result.WentToPenalties && _result.HomeGoals == _result.AwayGoals;
            <div class="board fade-up">
                <div class="board__comp">@comp.Emblem @Loc[comp.Name]</div>
                <div class="board__stage">@_stageLabel · @Loc["FINAL"]</div>
                <div class="board__main">
                    <div class="board__team"><div class="board__flag">⚽</div><div class="board__tname">@Game.State.ClubName</div></div>
                    <div class="board__score">
                        <span class="board__num">@_result.HomeGoals</span><span class="sep">–</span><span class="board__num">@_result.AwayGoals</span>
                    </div>
                    <div class="board__team"><div class="board__flag">@_result.AwayFlag</div><div class="board__tname">@_result.AwayName</div></div>
                </div>
                @if (_result.WentToPenalties) { <div class="board__pens">@Loc["PENALES"] · @_result.HomePens – @_result.AwayPens</div> }
            </div>

            <div class="result-banner @(win ? "win" : "lose")">
                <div class="result-banner__title">@(win ? Loc["¡VICTORIA!"] : draw ? Loc["EMPATE"] : Loc["DERROTA"])</div>
                @if (_reward > 0) { <div class="result-banner__reward">+ $@_reward M @Loc["en premios"] 💰</div> }
                @if (_gate > 0) { <div class="result-banner__reward">+ $@_gate M @Loc["de recaudación"] 🎟️</div> }
            </div>
        }

        @if (run.Champion)
        {
            <div class="champ-cele">
                <div class="champ-cele__confetti">@for (int i = 0; i < 40; i++) { <span style="--i:@i"></span> }</div>
                <div class="card card--pad center" style="margin-top:16px; border-color:rgba(245,197,66,.6); position:relative; z-index:2;">
                    <div class="trophy champ-cele__trophy">🏆</div>
                    <h2 style="font-family:var(--font-display); font-size:38px; color:var(--gold-2); margin-top:6px;">@Loc["¡CAMPEÓN!"]</h2>
                    <p class="muted">@Loc[comp.Name]</p>
                    @if (run.CleanRun) { <div class="pill pill--gold" style="margin-top:8px; padding:8px 14px;">@Loc["⭐ CAMPEÓN INVICTO SIN RECIBIR GOLES"]</div> }
                    <div class="mt"><button class="btn btn--gold btn--big" @onclick="Conclude">@Loc["Cobrar y volver"]</button></div>
                </div>
            </div>
        }
        else if (run.Eliminated)
        {
            <div class="card card--pad center" style="margin-top:16px;">
                @if (comp.Format == CompetitionFormat.League)
                {
                    <div style="font-size:50px;">🏁</div>
                    <h2 style="font-family:var(--font-head); font-size:26px; margin-top:6px;">@Loc[comp.Name]</h2>
                    <div class="pill pill--gold" style="margin-top:8px; padding:8px 14px;">
                        @Loc["Temporada terminada"] · @Game.LeaguePosition(run)º
                    </div>
                }
                else
                {
                    <div style="font-size:50px;">🚪</div>
                    <h2 style="font-family:var(--font-head); font-size:26px; margin-top:6px;">@Loc[comp.Name]</h2>
                }
                <p class="muted">@Loc["Reforzá el equipo y volvé más fuerte."]</p>
                <div class="mt"><button class="btn btn--gold btn--big" @onclick="Conclude">@Loc["Volver al mercado"]</button></div>
            </div>
        }
        else if (_result is not null)
        {
            <div class="center" style="margin-top:16px;">
                <button class="btn btn--gold btn--big" @onclick="NextMatch">@Game.StageInfo().stageName ▶</button>
            </div>
        }
        else
        {
            <div class="center" style="margin-top:16px;">
                <button class="btn btn--gold btn--big" @onclick="Conclude">@Loc["Volver"]</button>
            </div>
        }
    }

    @if (comp.Format == CompetitionFormat.League && run.Table.Count > 0 && _phase != Phase.Playing)
    {
        <div class="section-title"><span class="dot"></span> @Loc["Tabla de posiciones"]</div>
        <div class="card table-wrap">
            <table class="ltable">
                <thead>
                    <tr>
                        <th>#</th><th class="ltable__team">@Loc["Equipo"]</th>
                        <th>PJ</th><th>G</th><th>E</th><th>P</th><th>GF</th><th>GC</th><th>DIF</th><th>PTS</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int pos = 0; }
                    @foreach (var row in GameService.Standings(run))
                    {
                        pos++;
                        <tr class="@(row.IsMe ? "me" : "")">
                            <td>@pos</td>
                            <td class="ltable__team">@row.Flag @row.Name</td>
                            <td>@row.Played</td><td>@row.Won</td><td>@row.Drawn</td><td>@row.Lost</td>
                            <td>@row.GoalsFor</td><td>@row.GoalsAgainst</td>
                            <td>@(row.Diff > 0 ? "+" : "")@row.Diff</td>
                            <td class="ltable__pts">@row.Points</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    @if (run.Timeline.Count > 0 && _phase != Phase.Playing)
    {
        <div class="section-title"><span class="dot"></span> @Loc["Recorrido en la"] @Loc[comp.Name]</div>
        <div class="grid" style="gap:8px;">
            @foreach (var line in run.Timeline)
            {
                <div class="card" style="padding:12px 16px; font-family:var(--font-head); letter-spacing:.02em;">@line</div>
            }
        </div>
    }
}

@code {
    private enum Phase { Pre, Playing, Done }
    private Phase _phase = Phase.Pre;

    private MatchTimeline? _timeline;
    private MatchResult? _result;
    private int _reward, _gate;
    private string _stageLabel = "";

    protected override void OnInitialized()
    {
        base.OnInitialized();
        SyncDone();
    }

    // Cuando el estado carga (async) o cambia, si el torneo terminó pasamos a la pantalla final.
    protected override void OnGameChanged() => SyncDone();

    private void SyncDone()
    {
        var run = Game.State.Run;
        if (run is not null && (run.Champion || run.Eliminated) && _phase == Phase.Pre)
        {
            _phase = Phase.Done;
            _result = Game.LastMatch;
        }
    }

    private void Play()
    {
        _stageLabel = Game.StageInfo().stageName;
        _timeline = Game.SimulateNextTimeline();   // sólo el 1T
        _phase = Phase.Playing;
        _vestuario = false;
        _cambios.Clear();
        StateHasChanged();
    }

    // ---- Entretiempo ----
    private MatchField? _campo;
    private bool _vestuario;
    private string _sale = "", _entra = "", _result0 = "";
    private readonly List<string> _cambios = new();

    private void AbrirVestuario()
    {
        _result0 = $"{_timeline!.Result.HomeGoals} – {_timeline.Result.AwayGoals}";
        _vestuario = true;
        StateHasChanged();
    }

    /// <summary>
    /// El panel de cambio, compartido entre la previa y el entretiempo. En la
    /// previa (previa: true) no descuenta de los tres cambios: estás ARMANDO el
    /// equipo, no cambiando en pleno partido.
    /// </summary>
    private RenderFragment PanelCambio(bool previa) => __builder =>
    {
        bool hayCupo = previa || Game.CambiosDisponibles > 0;
        <div class="row wrap mt" style="gap:8px; align-items:flex-end;">
            <label class="pickr" style="flex-direction:column; align-items:flex-start; gap:4px;">
                <span>@Loc["Sale"]</span>
                <select class="mkt-select" @bind="_sale">
                    <option value="">—</option>
                    @foreach (var pl in Game.Starters)
                    {
                        <option value="@pl.Id">@pl.Rating · @Short(pl.Name)</option>
                    }
                </select>
            </label>
            <label class="pickr" style="flex-direction:column; align-items:flex-start; gap:4px;">
                <span>@Loc["Entra"]</span>
                <select class="mkt-select" @bind="_entra">
                    <option value="">—</option>
                    @foreach (var pl in Game.AvailableBench)
                    {
                        <option value="@pl.Id">@pl.Rating · @Short(pl.Name)</option>
                    }
                </select>
            </label>
            <button class="btn btn--gold"
                    disabled="@(!hayCupo || string.IsNullOrEmpty(_sale) || string.IsNullOrEmpty(_entra))"
                    @onclick="() => HacerCambio(previa)">🔄 @Loc["Cambiar"]</button>
        </div>
        @if (previa ? _cambiosPrevia.Count > 0 : _cambios.Count > 0)
        {
            <div class="grid mt" style="gap:6px;">
                @foreach (var c in (previa ? _cambiosPrevia : _cambios))
                {
                    <div class="faint" style="font-size:12.5px;">🔄 @c</div>
                }
            </div>
        }
    };

    private readonly List<string> _cambiosPrevia = new();

    private void HacerCambio(bool previa)
    {
        var sale = Game.Starters.FirstOrDefault(p => p.Id == _sale);
        var entra = Game.Owned.FirstOrDefault(p => p.Id == _entra);
        if (sale is null || entra is null) return;

        if (previa)
        {
            // En la previa es un ajuste del XI, sin gastar cambios ni límite.
            Game.SwapStarter(_sale, _entra);
            _cambiosPrevia.Add($"{Short(sale.Name)} → {Short(entra.Name)}");
            _sale = ""; _entra = "";
            return;
        }

        if (Game.Cambiar(_sale, _entra))
        {
            _cambios.Add($"{Short(sale.Name)} → {Short(entra.Name)}");
            _sale = ""; _entra = "";
        }
    }

    /// <summary>
    /// Jugadores TUYOS que se lesionaron durante el primer tiempo y siguen en el
    /// XI: hay que sacarlos sí o sí antes de salir al segundo tiempo.
    /// </summary>
    private List<Player> LesionadosObligatorios()
    {
        if (_timeline is null) return new();
        var enXI = Game.Starters.ToDictionary(p => p.Id);
        return _timeline.Events
            .Where(e => e.Type == SimEventType.Injury && e.Team == 0 && !string.IsNullOrEmpty(e.ActorId))
            .Select(e => e.ActorId!)
            .Distinct()
            .Where(id => enXI.ContainsKey(id))
            .Select(id => enXI[id])
            .ToList();
    }

    private void SalirAlSegundoTiempo()
    {
        // Se juega el 2T con el equipo y el planteo que quedaron, y se le agrega
        // al MISMO timeline que la cancha está reproduciendo.
        Game.SimularSegundoTiempo();
        _vestuario = false;
        StateHasChanged();
        _campo?.Reanudar();
    }

    private static string Short(string n)
    {
        n = OnceDeOro.Data.PrimeDatabase.BaseName(n);
        var partes = n.Split(' ');
        return partes.Length == 1 ? n : partes[^1];
    }

    private void OnMatchFinished()
    {
        _result = Game.LastMatch;
        _reward = Game.ApplyMatch(_result!);
        _gate = Game.LastGateM;          // lo que dejó la gente en la puerta
        _phase = Phase.Done;

        var run = Game.State.Run;
        if (run is not null && run.Champion) Sfx.Play("victory");
        else if (run is not null && run.Eliminated) Sfx.Play("defeat");
        else if (_result is not null && _result.HomeWon) Sfx.Play("roar");

        StateHasChanged();
    }

    private void NextMatch()
    {
        _phase = Phase.Pre;
        _timeline = null; _result = null; _reward = 0; _gate = 0;
        StateHasChanged();
    }

    private void Conclude()
    {
        Game.ConcludeTournament();
        Nav.NavigateTo("");
    }

    private static string Pc(double v) => Math.Round(v * 100) + "%";
}
