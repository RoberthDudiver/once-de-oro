@page "/equipo"
@inherits GamePageBase
@inject NavigationManager Nav

<PageTitle>Equipo — Once de Oro</PageTitle>

<div class="section-title"><span class="dot"></span> @Loc["Mi equipo"]</div>

@if (!Game.Owned.Any())
{
    <div class="empty">
        <div class="empty__ico">👕</div>
        <p>@Loc["No tenés jugadores todavía."]</p>
        <button class="btn btn--gold mt" @onclick='() => Nav.NavigateTo("mercado")'>@Loc["💰 Ir al mercado"]</button>
    </div>
}
else
{
    <div class="grid team-grid">
        <div>
            <div class="card card--pad mb">
                <div class="muted" style="font-size:12px; letter-spacing:.2em; text-transform:uppercase; margin-bottom:8px;">@Loc["Nombre del club"]</div>
                <input class="search" style="margin:0 0 14px;" maxlength="26" placeholder="@Loc["Nombre de tu equipo"]"
                       value="@Game.State.ClubName" @onchange="OnNameChange" />
                <div class="muted" style="font-size:12px; letter-spacing:.2em; text-transform:uppercase; margin-bottom:8px;">@Loc["Formación"]</div>
                <div class="seg wrap">
                    @foreach (var f in Formation.All)
                    {
                        <button class="@(Game.Formation.Name == f.Name ? "on" : "")" @onclick="() => Game.SetFormation(f.Name)">@f.Name</button>
                    }
                </div>
                <div class="muted" style="font-size:12px; letter-spacing:.2em; text-transform:uppercase; margin:14px 0 8px;">@Loc["Estilo"]</div>
                <div class="seg">
                    @foreach (var s in Enum.GetValues<TeamStyle>())
                    {
                        <button class="@(Game.State.Style == s ? "on" : "")" @onclick="() => Game.SetStyle(s)">@Loc[s.ToString()]</button>
                    }
                </div>
            </div>

            @* La cancha va adentro del estadio: las gradas se pintan alrededor con
               los colores del club. *@
            <div class="stadium" data-stands="@Game.State.Stands"
                 style="--c1:@Game.State.Primary; --c2:@Game.State.Secondary; --grada:@(Game.Stadium.GradaPx)px;">
                <div class="stand"></div>
            <div class="pitch">
                <div class="pitch__circle"></div>
                @* Cada línea es una fila flex: el navegador la reparte y NUNCA se sale de la cancha. *@
                @foreach (var line in Lines())
                {
                    <div class="pitch__line @(line.Slots.Count == 1 ? "pitch__line--solo" : "")" style="top:@(line.Y)%;">
                        @foreach (var slot in line.Slots)
                        {
                            <div class="pitch__slot"
                                 @onclick="() => { if (slot.Player is Player sp && !Game.IsReserve(sp)) Game.ToggleStarter(sp.Id); }">
                                @{ var pl = slot.Player!; var res = Game.IsReserve(pl); }
                                <div class="pitch__pos pos--@slot.Pos">@slot.Pos.Label()</div>
                                <div class="dot-player @(res ? "reserve" : "kit")">@pl.Rating</div>
                                <div class="pitch__name">@(res ? Loc["libre"] : Short(pl.Name))</div>
                            </div>
                        }
                    </div>
                }
            </div>
            </div>
        </div>

        <div>
            <div class="card card--pad mb">
                <div class="row" style="justify-content:space-between;">
                    <h3 style="font-size:19px;">@Loc["Fuerza"]</h3>
                    <button class="btn btn--ghost" style="padding:8px 14px; font-size:13px;" @onclick="() => Game.AutoFillXI()">@Loc["⚡ Auto XI"]</button>
                </div>
                @{ var pw = Game.Power; }
                <div class="power mt">
                    <div class="pbar"><span class="pbar__lbl">GEN</span><div class="pbar__track"><div class="pbar__fill" style="width:@(Math.Min(100, pw.Overall))%"></div></div><span class="pbar__num">@pw.Overall</span></div>
                    <div class="pbar"><span class="pbar__lbl">ATA</span><div class="pbar__track"><div class="pbar__fill atk" style="width:@(Math.Min(100, pw.Attack))%"></div></div><span class="pbar__num">@pw.Attack</span></div>
                    <div class="pbar"><span class="pbar__lbl">DEF</span><div class="pbar__track"><div class="pbar__fill def" style="width:@(Math.Min(100, pw.Defense))%"></div></div><span class="pbar__num">@pw.Defense</span></div>
                </div>
                <div class="mt">
                    @if (Game.HasFullRealXI)
                    {
                        <span class="pill pill--green" style="width:100%; justify-content:center; padding:9px;">@Loc["✓ XI TITULAR COMPLETO — LISTO PARA JUGAR"]</span>
                    }
                    else
                    {
                        <span class="pill pill--gold" style="width:100%; justify-content:center; padding:9px;">
                            🎓 @Game.ReserveCount @Loc["de cantera cubren los huecos — igual podés jugar"]
                        </span>
                    }
                </div>
            </div>

        @* Va JUNTO a la cancha: elegis los colores y las gradas viendo el cambio. *@
        <div class="section-title"><span class="dot"></span> @Loc["🎨 Camiseta y estadio"]</div>
        <div class="card card--pad mb">
            <div class="muted" style="font-size:12px; letter-spacing:.2em; text-transform:uppercase; margin-bottom:10px;">@Loc["Colores del club"]</div>
            <div class="kits mb">
                @foreach (var k in GameService.Kits)
                {
                    var elegido = Game.State.Primary == k.P && Game.State.Secondary == k.S;
                    <button class="kit-chip @(elegido ? "on" : "")" title="@k.Name"
                            @onclick="() => Game.SetColors(k.P, k.S)">
                        <span class="kit-chip__a" style="background:@k.P"></span>
                        <span class="kit-chip__b" style="background:@k.S"></span>
                    </button>
                }
            </div>

            <div class="row wrap" style="gap:16px;">
                <label class="pickr">
                    <span>@Loc["Principal"]</span>
                    <input type="color" value="@Game.State.Primary"
                           @onchange="CambiarPrincipal" />
                </label>
                <label class="pickr">
                    <span>@Loc["Secundario"]</span>
                    <input type="color" value="@Game.State.Secondary"
                           @onchange="CambiarSecundario" />
                </label>
            </div>

            <div class="muted" style="font-size:12px; letter-spacing:.2em; text-transform:uppercase; margin:18px 0 10px;">@Loc["Gradas"]</div>
            <div class="stands-pick">
                @foreach (var s in GameService.StandStyles)
                {
                    <button class="standopt @(Game.State.Stands == s.Key ? "on" : "")"
                            @onclick="() => Game.SetStands(s.Key)">
                        <span class="standopt__prev" data-stands="@s.Key"
                              style="--c1:@Game.State.Primary; --c2:@Game.State.Secondary;"></span>
                        <b>@Loc[s.Name]</b>
                        <span class="faint">@Loc[s.Desc]</span>
                    </button>
                }
            </div>
        </div>
        </div>
    </div>

    <div class="section-title"><span class="dot"></span> @Loc["Plantel"] (@Game.Owned.Count()) · @Loc["tocá para poner/sacar del XI"]</div>
    <div class="seg wrap mb">
        <button class="@(PlantelPos is null ? "on" : "")" @onclick="() => PlantelPos = null">@Loc["Todos"]</button>
        <button class="@(PlantelPos == Position.GK ? "on" : "")" @onclick="() => PlantelPos = Position.GK">POR (@Game.Owned.Count(p => p.Pos == Position.GK))</button>
        <button class="@(PlantelPos == Position.DEF ? "on" : "")" @onclick="() => PlantelPos = Position.DEF">DEF (@Game.Owned.Count(p => p.Pos == Position.DEF))</button>
        <button class="@(PlantelPos == Position.MID ? "on" : "")" @onclick="() => PlantelPos = Position.MID">MED (@Game.Owned.Count(p => p.Pos == Position.MID))</button>
        <button class="@(PlantelPos == Position.FWD ? "on" : "")" @onclick="() => PlantelPos = Position.FWD">DEL (@Game.Owned.Count(p => p.Pos == Position.FWD))</button>
    </div>
    <div class="grid grid--cards">
        @foreach (var p in Game.Owned.Where(x => PlantelPos is null || x.Pos == PlantelPos).OrderByDescending(x => Game.IsStarter(x.Id)).ThenByDescending(x => x.Rating))
        {
            <PlayerCard P="p" ShowPrice="false" OnOpen="Abrir">
                <Actions>
                    @* Al que no puede jugar (lesionado o suspendido) sólo se lo puede sacar. *@
                    <button class="icon-btn @(Game.IsStarter(p.Id) ? "icon-btn--sell" : "icon-btn--buy")"
                            disabled="@(!Game.IsStarter(p.Id) && Game.IsOut(p.Id))"
                            title="@(Game.IsStarter(p.Id) ? Loc["Sacar del XI"]
                                     : Game.IsInjured(p.Id) ? Loc["Lesionado: no puede jugar"]
                                     : Game.IsSuspended(p.Id) ? Loc["Suspendido: no puede jugar"]
                                     : Loc["Poner en el XI"])"
                            @onclick="() => Game.ToggleStarter(p.Id)">
                        @(Game.IsStarter(p.Id) ? "−"
                          : Game.IsInjured(p.Id) ? "🚑"
                          : Game.IsSuspended(p.Id) ? "🟥" : "＋")
                    </button>
                </Actions>
            </PlayerCard>
        }
    </div>
    @* ---------------- Concentración: 1 minuto y vuelven enteros ---------------- *@
    <div class="section-title"><span class="dot"></span> @Loc["🛌 Concentración"]</div>
    <div class="card card--pad mb">
        <div class="row wrap" style="justify-content:space-between; gap:10px;">
            <div class="faint" style="font-size:12.5px; max-width:520px;">
                @Loc["Mandalos a concentrar y en 1 minuto vuelven enteros. Mientras descansan no pueden jugar: ese es el precio."]
            </div>
            @if (Cansados().Any())
            {
                <button class="btn btn--gold" @onclick="() => Game.RestAll()">
                    @Loc["😴 Que descansen todos"] (@Cansados().Count())
                </button>
            }
        </div>

        @if (!Cansados().Any() && !Descansando().Any())
        {
            <div class="muted mt" style="font-size:13px;">@Loc["Están todos enteros. A jugar."]</div>
        }

        <div class="grid mt" style="gap:8px;">
            @foreach (var p in Descansando())
            {
                <div class="rest rest--on">
                    <span class="rest__name">😴 @p.Name</span>
                    <span class="rest__bar"><i style="width:@RestPct(p.Id)%"></i></span>
                    <span class="rest__time">@RestLabel(p.Id)</span>
                </div>
            }
            @foreach (var p in Cansados())
            {
                <div class="rest">
                    <span class="rest__name">@p.Name</span>
                    <span class="rest__fat">😮‍💨 @Game.FatigueOf(p.Id)%</span>
                    <button class="btn btn--ghost rest__btn" @onclick="() => Game.Rest(p.Id)">@Loc["Descansar"]</button>
                </div>
            }
        </div>
    </div>

    @* ---------------- Fusión de primes ---------------- *@
    var fusiones = Fusionables();
    @if (fusiones.Count > 0)
    {
        <div class="section-title"><span class="dot"></span> @Loc["⬆️ Fusiones disponibles"]</div>
        <div class="card card--pad mb">
            <div class="faint mb" style="font-size:12.5px;">
                @Loc["Tenés la versión común de estos jugadores. Sacrificala y su versión prime sube un punto."]
            </div>
            <div class="grid" style="gap:8px;">
                @foreach (var (prime, comun) in fusiones)
                {
                    <div class="fuse">
                        <div class="fuse__txt">
                            <b>@prime.Name</b> @prime.Rating → <b>@(prime.Rating + 1)</b>
                            <div class="faint">@Loc["Se pierde"] @comun.Name (@comun.Rating)</div>
                        </div>
                        <button class="btn btn--gold" @onclick="() => Game.Fuse(prime.Id)">
                            @Loc["Mejorar"] · @prime.Rating → @(prime.Rating + 1)
                        </button>
                    </div>
                }
            </div>
        </div>
    }

    @* ---------------- Roles del equipo ---------------- *@
    <div class="section-title"><span class="dot"></span> @Loc["🎖️ Roles del equipo"]</div>
    <div class="card card--pad mb">
        <div class="faint mb" style="font-size:12.5px;">
            @Loc["Quién se hace cargo de cada pelota parada. Si dejás uno sin asignar, lo elige el equipo solo."]
        </div>
        <div class="roles">
            @foreach (var r in GameService.Roles)
            {
                <label class="rolrow">
                    <span class="rolrow__lbl">@r.Icono @Loc[r.Nombre]</span>
                    <select class="mkt-select" value="@Game.RolDe(r.Key)"
                            @onchange="e => Game.SetRol(r.Key, e.Value?.ToString() ?? string.Empty)">
                        <option value="">@Loc["— lo elige el equipo —"]</option>
                        @foreach (var p in Game.Starters.Where(x => x.Pos != Position.GK || r.Key == "cap"))
                        {
                            <option value="@p.Id">@p.Rating · @p.Name</option>
                        }
                    </select>
                </label>
            }
        </div>
    </div>

    @* ---------------- Órdenes del DT ---------------- *@
    <div class="section-title"><span class="dot"></span> @Loc["📋 Órdenes del DT"]</div>
    <div class="card card--pad mb">
        <div class="faint mb" style="font-size:12.5px;">
            @Loc["Una instrucción por titular. Cambian de verdad el ataque y la defensa del equipo."]
        </div>
        <div class="grid" style="gap:8px;">
            @foreach (var p in Game.Starters.Where(x => x.Pos != Position.GK))
            {
                var ops = GameService.OrdenesDe(p.Pos);
                var actual = Game.OrdenDe(p.Id);
                <div class="orden">
                    <div class="orden__quien">
                        <span class="pos pos--@p.Pos">@p.Pos.Label()</span>
                        <b>@Short(p.Name)</b>
                    </div>
                    <div class="seg wrap orden__ops">
                        <button class="@(actual == "" ? "on" : "")"
                                @onclick="() => Game.SetOrden(p.Id, string.Empty)">@Loc["Libre"]</button>
                        @foreach (var o in ops)
                        {
                            <button class="@(actual == o.Key ? "on" : "")" title="@Loc[o.Desc]"
                                    @onclick="() => Game.SetOrden(p.Id, o.Key)">@Loc[o.Nombre]</button>
                        }
                    </div>
                </div>
            }
        </div>
    </div>

}

<PlayerDetail P="_ficha" OnClose="() => _ficha = null" />

@code {
    private Player? _ficha;
    private void Abrir(Player p) => _ficha = p;

    // ---- Concentración ----
    // Un timer de un segundo mientras haya alguien descansando: es lo único que
    // necesita refrescarse solo (la cuenta regresiva y el alta automática).
    private System.Threading.Timer? _tick;

    // Se recalculan una vez por render y no en cada uso: Game.Owned resuelve cada
    // id contra todo el plantel, así que llamarlo cuatro veces por dibujo se nota
    // cuando tenés cientos de jugadores.
    private List<Player> _descansando = new();
    private List<Player> _cansados = new();

    private List<Player> Descansando() => _descansando;
    private List<Player> Cansados() => _cansados;

    /// <summary>
    /// Primes tuyos que YA se pueden mejorar porque tenés su versión común. Estaba
    /// sólo dentro de la ficha del jugador, al fondo de todo, así que no se
    /// encontraba: ahora también aparece acá, con el botón a la vista.
    /// </summary>
    private List<(Player Prime, Player Comun)> Fusionables()
    {
        var r = new List<(Player, Player)>();
        foreach (var p in Game.Owned)
        {
            var fuente = Game.FuseSource(p);
            if (fuente is not null) r.Add((p, fuente));
        }
        return r;
    }

    private void CambiarPrincipal(ChangeEventArgs e) =>
        Game.SetColors(e.Value?.ToString() ?? "", Game.State.Secondary);

    private void CambiarSecundario(ChangeEventArgs e) =>
        Game.SetColors(Game.State.Primary, e.Value?.ToString() ?? "");

    private void RecalcularDescanso()
    {
        var mios = Game.Owned.ToList();
        _descansando = mios.Where(p => Game.IsResting(p.Id)).ToList();
        _cansados = mios.Where(p => !Game.IsResting(p.Id) && !Game.IsInjured(p.Id) && Game.FatigueOf(p.Id) > 0)
                        .OrderByDescending(p => Game.FatigueOf(p.Id)).ToList();
    }

    protected override void OnGameChanged() => RecalcularDescanso();

    private string RestLabel(string id)
    {
        var t = Game.RestLeft(id);
        return $"{t.Minutes}:{t.Seconds:00}";
    }

    /// <summary>Cuánto del descanso ya cumplió, para la barrita.</summary>
    private int RestPct(string id)
    {
        double total = GameService.RestMinutes * 60.0;
        double falta = Game.RestLeft(id).TotalSeconds;
        return (int)Math.Round(Math.Clamp((total - falta) / total * 100, 0, 100));
    }

    protected override void OnInitialized()
    {
        base.OnInitialized();
        RecalcularDescanso();
        _tick = new System.Threading.Timer(_ =>
        {
            // Cierra los descansos cumplidos y redibuja la cuenta regresiva.
            Game.SettleRests();
            RecalcularDescanso();
            InvokeAsync(StateHasChanged);
        }, null, 1000, 1000);
    }

    public override void Dispose()
    {
        _tick?.Dispose();
        base.Dispose();
    }

    private Position? PlantelPos;
    private void OnNameChange(ChangeEventArgs e) => Game.SetClubName(e.Value?.ToString() ?? "");
    private record Slot(Position Pos, Player? Player);
    private record Line(double Y, List<Slot> Slots);

    private static readonly Dictionary<Position, double> LineY = new()
    {
        [Position.GK] = 85, [Position.DEF] = 65, [Position.MID] = 44, [Position.FWD] = 17
    };

    private List<Line> Lines()
    {
        var f = Game.Formation;
        var result = new List<Line>();
        // Se dibuja el XI que REALMENTE juega: sin lesionados y con la fuerza
        // que rinden hoy (el cansancio ya descontado). Si no, la cancha decía
        // una cosa y el partido jugaba otra.
        var xi = Game.EffectiveStarters;
        foreach (var pos in new[] { Position.FWD, Position.MID, Position.DEF, Position.GK })
        {
            int count = f.SlotsFor(pos);
            if (count == 0) continue;
            var players = xi.Where(p => p.Pos == pos).ToList();
            var slots = new List<Slot>();
            for (int i = 0; i < count; i++)
                slots.Add(new Slot(pos, i < players.Count ? players[i] : GameService.ReserveFor(pos, i)));
            result.Add(new Line(LineY[pos], slots));
        }
        return result;
    }

    private static string Tier(Player p) => p.Rating >= 85 ? "" : p.Rating >= 75 ? "silver" : "bronze";
    private static string Short(string name)
    {
        // Los primes se llaman "Lionel Messi (Prime 2012)": si tomamos la ultima
        // palabra queda "2012)", asi que primero se corta la marca del prime.
        name = PrimeDatabase.BaseName(name);
        var parts = name.Split(' ');
        return parts.Length == 1 ? name : parts[^1];
    }
}
