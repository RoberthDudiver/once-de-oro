@page "/analiticas"
@inherits GamePageBase
@inject StatsService Stats

<PageTitle>Análisis — Once de Oro</PageTitle>

<div class="section-title"><span class="dot"></span> @Loc["📊 Cuánta gente ha jugado"]</div>

@if (_cargando)
{
    <div class="card card--pad center muted">@Loc["Cargando…"]</div>
}
else if (_stats is null)
{
    <div class="card card--pad center">
        <div class="empty__ico">📴</div>
        <p class="muted">@Loc["El contador no está disponible en este momento."]</p>
    </div>
}
else
{
    <div class="grid mb" style="grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:12px;">
        <div class="statbox">
            <div class="statbox__n">@Fmt(_stats.Players)</div>
            <div class="statbox__l">🌍 @Loc["Jugadores"]</div>
        </div>
        <div class="statbox">
            <div class="statbox__n">@Fmt(_stats.Matches)</div>
            <div class="statbox__l">⚽ @Loc["Partidos jugados"]</div>
        </div>
        <div class="statbox">
            <div class="statbox__n">@Fmt(_stats.Active7d)</div>
            <div class="statbox__l">🔥 @Loc["Activos esta semana"]</div>
        </div>
        <div class="statbox">
            <div class="statbox__n">@Fmt(_stats.Accounts)</div>
            <div class="statbox__l">👤 @Loc["Cuentas creadas"]</div>
        </div>
    </div>

    @if (_stats.ByLang.Count > 0 && _stats.Matches > 0)
    {
        <div class="section-title"><span class="dot"></span> @Loc["Partidos por idioma"]</div>
        <div class="card card--pad">
            @foreach (var (code, name) in Loc.Languages.Select(l => (l.Code, l.Name)))
            {
                var val = _stats.ByLang.GetValueOrDefault(code, 0);
                var pct = _stats.Matches > 0 ? (int)Math.Round(100.0 * val / _stats.Matches) : 0;
                <div class="langrow">
                    <span class="langrow__l">@name</span>
                    <div class="langrow__bar"><i style="width:@pct%"></i></div>
                    <span class="langrow__n">@pct%</span>
                </div>
            }
        </div>
    }

    <p class="faint mt" style="font-size:11.5px;">
        @Loc["El conteo es anónimo: cada navegador tiene un código aleatorio, sin correo ni nombre. Ver Créditos y privacidad."]
    </p>
}

@code {
    private bool _cargando = true;
    private GlobalStats? _stats;

    protected override async Task OnInitializedAsync()
    {
        base.OnInitialized();
        _stats = await Stats.GetAsync();
        _cargando = false;
    }

    /// <summary>1 234 → "1.234"; los millones se abrevian.</summary>
    private static string Fmt(long n) =>
        n >= 1_000_000 ? (n / 1_000_000.0).ToString("0.#") + "M"
        : n.ToString("#,0", System.Globalization.CultureInfo.GetCultureInfo("es-AR"));
}
