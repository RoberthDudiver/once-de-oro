@page "/"
@inherits GamePageBase
@inject NavigationManager Nav

<PageTitle>Once de Oro — Manager</PageTitle>

<section class="hero fade-up">
    <div class="hero__eyebrow">@Loc["★ Temporada abierta"]</div>
    <h1 class="hero__title">ARMÁ TU <em>ONCE</em><br />DE ORO</h1>
    <p class="hero__sub">
        @Loc["Empezás de cero con tu presupuesto. Fichá leyendas de todos los Mundiales, ganá torneos, cobrá premios y volvé al mercado por más estrellas. La meta legendaria: ser campeón sin recibir un solo gol."]
    </p>
    <div class="hero__cta">
        @if (Game.State.Run is not null)
        {
            <button class="btn btn--gold btn--big" @onclick="@(() => Nav.NavigateTo("partido"))">
                @Loc["▶ Continuar torneo"]
            </button>
        }
        else if (Game.Owned.Any())
        {
            <button class="btn btn--gold btn--big" @onclick="@(() => Nav.NavigateTo("torneos"))">
                @Loc["🏆 Inscribirse a un torneo"]
            </button>
        }
        else
        {
            <button class="btn btn--gold btn--big" @onclick="@(() => Nav.NavigateTo("mercado"))">
                @Loc["💰 Ir al mercado de fichajes"]
            </button>
        }
        <button class="btn btn--ghost btn--big" @onclick="@(() => Nav.NavigateTo("equipo"))">
            @Loc["👕 Ver mi equipo"]
        </button>
    </div>
</section>

<div class="section-title"><span class="dot"></span> @Loc["Estado del club"]</div>

<div class="grid dash-grid">
    <div class="card card--pad">
        <div class="row" style="justify-content: space-between;">
            <h3 style="font-size:20px;">@Loc["Fuerza del equipo"]</h3>
            <span class="pill pill--gold">@(Game.HasFullRealXI ? Loc["XI TITULAR COMPLETO"] : $"{Game.ReserveCount} {Loc["DE CANTERA"]}")</span>
        </div>
        @{ var pw = Game.Power; }
        <div class="power mt">
            <div class="pbar">
                <span class="pbar__lbl">GEN</span>
                <div class="pbar__track"><div class="pbar__fill" style="width:@(Math.Min(100, pw.Overall))%"></div></div>
                <span class="pbar__num">@pw.Overall</span>
            </div>
            <div class="pbar">
                <span class="pbar__lbl">ATA</span>
                <div class="pbar__track"><div class="pbar__fill atk" style="width:@(Math.Min(100, pw.Attack))%"></div></div>
                <span class="pbar__num">@pw.Attack</span>
            </div>
            <div class="pbar">
                <span class="pbar__lbl">DEF</span>
                <div class="pbar__track"><div class="pbar__fill def" style="width:@(Math.Min(100, pw.Defense))%"></div></div>
                <span class="pbar__num">@pw.Defense</span>
            </div>
        </div>
        <div class="row wrap mt">
            <span class="pill">🧮 @Game.Owned.Count() @Loc["jugadores"]</span>
            <span class="pill">📋 @Game.Formation.Name</span>
            <span class="pill">🎯 @Loc[Game.State.Style.ToString()]</span>
        </div>
    </div>

    <div class="card card--pad">
        <h3 style="font-size:20px;">@Loc["Palmarés"]</h3>
        @if (Game.State.Honours.Count == 0)
        {
            <div class="empty" style="padding:26px 6px;">
                <div class="empty__ico">🏆</div>
                <p>@Loc["Todavía sin trofeos."]<br />@Loc["¡Salí a ganar tu primer título!"]</p>
            </div>
        }
        else
        {
            <div class="grid mt" style="gap:8px;">
                @foreach (var group in Game.State.Honours.GroupBy(h => h))
                {
                    <div class="row" style="justify-content:space-between;">
                        <span class="row"><span style="font-size:20px;">🏆</span> @group.Key</span>
                        <span class="pill pill--gold">×@group.Count()</span>
                    </div>
                }
            </div>
        }
        @if (Game.State.AchievedSevenZero)
        {
            <div class="pill pill--gold mt" style="width:100%; justify-content:center; padding:10px;">
                @Loc["⭐ CAMPEÓN INVICTO SIN RECIBIR GOLES"]
            </div>
        }
    </div>
</div>

<div class="section-title"><span class="dot"></span> @Loc["Carrera"]</div>
<div class="stats">
    <div class="stat"><div class="stat__val gold">@Game.State.MatchesPlayed</div><div class="stat__lbl">@Loc["Partidos"]</div></div>
    <div class="stat"><div class="stat__val" style="color:var(--green)">@Game.State.Wins</div><div class="stat__lbl">@Loc["Ganados"]</div></div>
    <div class="stat"><div class="stat__val">@Game.State.Draws</div><div class="stat__lbl">@Loc["Empates"]</div></div>
    <div class="stat"><div class="stat__val" style="color:var(--red)">@Game.State.Losses</div><div class="stat__lbl">@Loc["Perdidos"]</div></div>
    <div class="stat"><div class="stat__val">@Game.State.GoalsFor</div><div class="stat__lbl">@Loc["Goles a favor"]</div></div>
    <div class="stat"><div class="stat__val">@Game.State.GoalsAgainst</div><div class="stat__lbl">@Loc["En contra"]</div></div>
</div>

@if (Game.State.History.Count > 0)
{
    <div class="section-title"><span class="dot"></span> @Loc["Historial de torneos"]</div>
    <div class="grid" style="gap:8px;">
        @foreach (var h in Game.State.History)
        {
            <div class="card" style="padding:12px 16px; font-family:var(--font-head); letter-spacing:.01em; font-size:14px;">@h</div>
        }
    </div>
}

<div class="center" style="margin-top:34px;">
    <button class="btn btn--danger" @onclick="Reset">@Loc["↺ Reiniciar carrera"]</button>
</div>

@code {
    private async Task Reset()
    {
        await Game.ResetAsync();
        Nav.NavigateTo("mercado");
    }
}
