@page "/academia"
@inherits GamePageBase

<PageTitle>Academia — Once de Oro</PageTitle>

@* Tres apartados separados para que cada cosa tenga su lugar *@
<div class="seg wrap mb" style="margin-top:18px;">
    <button class="@(Tab == "cantera" ? "on" : "")" @onclick='() => Tab = "cantera"'>🎓 @Loc["Cantera"]</button>
    <button class="@(Tab == "copa" ? "on" : "")" @onclick='() => Tab = "copa"'>🏅 @Loc["Copa juvenil"]</button>
    <button class="@(Tab == "ojeadores" ? "on" : "")" @onclick='() => Tab = "ojeadores"'>
        🔍 @Loc["Ojeadores"]
        @if (Game.State.Prospects.Count > 0) { <span class="badge-n">@Game.State.Prospects.Count</span> }
    </button>
    <button class="@(Tab == "mejoras" ? "on" : "")" @onclick='() => Tab = "mejoras"'>🎟️ @Loc["Mejoras"]</button>
</div>

@if (Tab == "mejoras")
{
<div class="section-title"><span class="dot"></span> @Loc["Tokens de mejora"]</div>

<div class="card card--pad mb">
    <div class="row wrap" style="justify-content:space-between; gap:12px;">
        <div>
            <div class="tok__count">🎟️ @Game.State.Tokens</div>
            <div class="muted" style="font-size:12.5px;">@Loc["Sirven para subir de nivel a cualquier jugador tuyo, hasta 99."]</div>
        </div>
        <div class="row wrap" style="gap:8px;">
            @foreach (var q in new[] { 1, 5, 10 })
            {
                <button class="btn btn--ghost" style="padding:9px 13px;"
                        disabled="@(!Game.CanBuyTokens(q))" @onclick="() => Game.BuyTokens(q)">
                    +@q · $@(q * GameService.TokenCost)M
                </button>
            }
        </div>
    </div>
</div>

@if (Game.Owned.Any())
{
    <div class="card card--pad mb">
        <div class="muted" style="font-size:12.5px; margin-bottom:10px;">
            @Loc["Cuanto más fuerte es el jugador, más tokens cuesta cada punto. Así mejorar a una estrella es una inversión de verdad."]
        </div>
        <div class="upg">
            @foreach (var p in Game.Owned.OrderByDescending(x => x.Rating).Take(30))
            {
                var tope = p.Rating >= GameService.MaxRating;
                var costo = GameService.TokensToUpgrade(p.Rating);
                var alcanza = Game.State.Tokens >= costo;
                var mejoras = Game.UpgradeOf(p.Id);
                <div class="upg__row">
                    <span class="dot-player @Tier(p.Rating)" style="width:38px;height:38px;font-size:15px;">@p.Rating</span>
                    <span class="upg__name">
                        @p.Name
                        @if (mejoras > 0) { <span class="upg__plus">+@mejoras</span> }
                    </span>
                    <button class="btn @(alcanza && !tope ? "btn--gold" : "btn--ghost")" style="padding:7px 12px; font-size:12.5px;"
                            disabled="@(tope || !alcanza)" @onclick="() => Game.UpgradePlayer(p.Id)">
                        @(tope ? Loc["Máximo"] : $"▲ {costo} 🎟️")
                    </button>
                </div>
            }
        </div>
    </div>
}
}

@* ============================= COPA JUVENIL 5v5 ============================= *@
@if (Tab == "copa")
{
    <div class="section-title"><span class="dot"></span> @Loc["Copa juvenil"] · 5 vs 5</div>
    <p class="muted" style="margin:0 0 14px; font-size:13.5px;">
        @Loc["Torneos de formación para tu cantera: cuestan plata y NO dan premio. Lo que ganás es experiencia. No cansan ni lesionan."]
    </p>

    @if (Game.State.Academy.Count < GameService.YouthSquadSize)
    {
        <div class="empty">
            <div class="empty__ico">🏅</div>
            <p>@Loc["Necesitás al menos 5 juveniles. Creá jugadores o fichá promesas con un ojeador."]</p>
        </div>
    }
    else
    {
        <div class="card card--pad mb">
            <div class="row" style="justify-content:space-between;">
                <h3 style="font-size:17px;">@Loc["Elegí 5 juveniles"]</h3>
                <span class="pill @(Elegidos.Count == GameService.YouthSquadSize ? "pill--green" : "")">
                    @Elegidos.Count/@GameService.YouthSquadSize
                </span>
            </div>
            <div class="ycal mt">
                @foreach (var a in Game.State.Academy.OrderByDescending(x => x.Rating))
                {
                    var sel = Elegidos.Contains(a.Id);
                    <button class="ypick @(sel ? "on" : "")" @onclick="() => Toggle(a.Id)">
                        <span class="dot-player @Tier(a.Rating)" style="width:34px;height:34px;font-size:14px;">@a.Rating</span>
                        <span class="ypick__n">@a.Name</span>
                        <span class="faint">@a.Pos.Label()</span>
                    </button>
                }
            </div>
        </div>

        <div class="grid grid--cards">
            @foreach (var cup in GameService.YouthCups)
            {
                <div class="card card--pad">
                    <div class="row" style="justify-content:space-between; align-items:flex-start;">
                        <div>
                            <div style="font-family:var(--font-head); font-size:17px;">@Loc[cup.Name]</div>
                            <div class="muted" style="font-size:12.5px; margin-top:3px;">@Loc[cup.Desc]</div>
                        </div>
                        <span class="pill">@Loc["Rival"] @cup.RivalStrength</span>
                    </div>
                    <div class="row wrap mt" style="gap:6px;">
                        <span class="pill">@cup.Matches @Loc["partidos"]</span>
                        <span class="pill pill--gold">+@cup.XpWin XP @Loc["por victoria"]</span>
                        <span class="pill">+@cup.XpPlay XP @Loc["por jugar"]</span>
                    </div>
                    <div class="mt">
                        <button class="btn btn--gold" style="width:100%; padding:11px;"
                                disabled="@(!Game.CanPlayYouth(cup, Elegidos))"
                                @onclick="() => Jugar(cup)">
                            @Loc["Jugar"] · $@cup.Cost M
                        </button>
                    </div>
                </div>
            }
        </div>

        @if (Game.LastYouth is { } r)
        {
            <div class="section-title"><span class="dot"></span> @Loc[r.CupName]</div>
            <div class="card card--pad">
                @if (r.Champion)
                {
                    <div class="center mb"><div class="trophy" style="font-size:44px;">🏅</div>
                        <div style="font-family:var(--font-display); font-size:26px; color:var(--gold-2);">@Loc["¡INVICTOS!"]</div></div>
                }
                @foreach (var m in r.Matches)
                {
                    <div class="yres @(m.Us > m.Them ? "win" : m.Us == m.Them ? "draw" : "lose")">
                        <span>@Loc["Tu cantera"]</span>
                        <b>@m.Us – @m.Them</b>
                        <span>@m.Rival</span>
                    </div>
                }
                <div class="row wrap mt" style="gap:8px;">
                    <span class="pill pill--green">@r.Won/@r.Matches.Count @Loc["ganados"]</span>
                    <span class="pill pill--gold">+@r.Xp XP @Loc["a cada juvenil"]</span>
                </div>
                @if (r.LeveledUp.Count > 0)
                {
                    <div class="real-note">⬆ @string.Join(" · ", r.LeveledUp)</div>
                }
            </div>
        }
    }
}

@* ================================ OJEADORES ================================ *@
@if (Tab == "ojeadores")
{
    <div class="section-title"><span class="dot"></span> @Loc["Contratar un ojeador"]</div>
    <p class="muted" style="margin:0 0 14px; font-size:13.5px;">
        @Loc["Los ojeadores buscan jóvenes promesas. Lo que pagás no es lo que rinden hoy, sino hasta dónde pueden llegar."]
    </p>

    <div class="grid grid--cards mb">
        @foreach (var s in GameService.Scouts)
        {
            <div class="card card--pad scout">
                <div class="row" style="justify-content:space-between; align-items:flex-start;">
                    <div>
                        <div style="font-family:var(--font-head); font-size:17px;">@Loc[s.Name]</div>
                        <div class="muted" style="font-size:12.5px; margin-top:3px;">@Loc[s.Desc]</div>
                    </div>
                    <span class="pill pill--gold">@s.MinPot–@s.MaxPot</span>
                </div>
                <div class="row mt" style="justify-content:space-between;">
                    <span class="muted" style="font-size:12.5px;">@Loc["Techo de las promesas"]</span>
                    <button class="btn btn--gold" style="padding:9px 14px;"
                            disabled="@(!Game.CanScout(s))" @onclick="() => Game.SendScout(s)">
                        $@s.Cost M · @Loc["Buscar"]
                    </button>
                </div>
            </div>
        }
    </div>

    @if (Game.State.Prospects.Count == 0)
    {
        <div class="empty">
            <div class="empty__ico">🔍</div>
            <p>@Loc["Todavía no encontraste promesas. Contratá un ojeador."]</p>
        </div>
    }
    else
    {
        <div class="section-title"><span class="dot"></span> @Loc["Promesas encontradas"] (@Game.State.Prospects.Count)</div>
        <div class="grid grid--cards">
            @foreach (var pr in Game.State.Prospects.OrderByDescending(x => x.Potential))
            {
                <div class="card card--pad">
                    <div class="row" style="justify-content:space-between; align-items:flex-start;">
                        <div class="row">
                            <div class="dot-player @Tier(pr.Rating)" style="width:46px;height:46px;font-size:18px;">@pr.Rating</div>
                            <div>
                                <div style="font-family:var(--font-head); font-size:16px;">@pr.Name</div>
                                <div class="muted" style="font-size:12px;">
                                    @pr.Flag @pr.Nation · @pr.Pos.Full() · @pr.Age @Loc["años"]
                                </div>
                            </div>
                        </div>
                        <span class="pill @(pr.Potential >= 90 ? "pill--gold" : "")">▲ @pr.Potential</span>
                    </div>

                    <div class="pot mt">
                        <div class="pot__bar">
                            <span class="pot__now" style="width:@(pr.Rating)%"></span>
                            <span class="pot__max" style="width:@(pr.Potential)%"></span>
                        </div>
                        <div class="row" style="justify-content:space-between; font-size:11.5px; color:var(--ink-faint); margin-top:4px;">
                            <span>@Loc["Hoy"] @pr.Rating</span>
                            <span>@Loc["Puede llegar a"] @pr.Potential</span>
                        </div>
                    </div>

                    <div class="row wrap mt" style="gap:8px;">
                        <button class="btn btn--gold" style="flex:1; padding:10px;"
                                disabled="@(Game.State.Money < pr.Cost)" @onclick="() => Game.SignProspect(pr.Id)">
                            @Loc["Fichar"] · $@pr.Cost M
                        </button>
                        <button class="btn btn--ghost" style="padding:10px 12px;" @onclick="() => Game.DiscardProspect(pr.Id)">✕</button>
                    </div>
                    <div class="faint" style="font-size:11px; margin-top:6px;">@Loc[pr.ScoutName]</div>
                </div>
            }
        </div>
    }
}

@* ================================ CANTERA ================================ *@
@if (Tab == "cantera")
{
<div class="section-title"><span class="dot"></span> @Loc["Academia"]</div>

<div class="card card--pad mb">
    <p class="muted" style="margin:0 0 14px; font-size:13.5px;">
        @Loc["Creá tus propios jugadores y hacelos crecer entrenando y jugando. Entrenar cuesta cada vez más caro: es donde tu fortuna encuentra destino."]
    </p>

    <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(160px,1fr)); gap:12px;">
        <label class="fld">@Loc["Nombre"]
            <input class="search" style="margin:6px 0 0;" maxlength="22" @bind="_name" placeholder="@Loc["Tu joya"]" />
        </label>
        <label class="fld">@Loc["País"]
            <input class="search" style="margin:6px 0 0;" maxlength="18" @bind="_nation" placeholder="@Loc["Cantera"]" />
        </label>
        <div class="fld">@Loc["Puesto"]
            <div class="seg wrap" style="margin-top:6px;">
                @foreach (var p in Enum.GetValues<Position>())
                {
                    <button class="@(_pos == p ? "on" : "")" @onclick="() => _pos = p">@p.Label()</button>
                }
            </div>
        </div>
    </div>

    <div class="row wrap mt" style="gap:10px; justify-content:space-between;">
        <span class="pill pill--gold">@Loc["Costo"] $@GameService.AcademyCreateCost M · @Loc["arranca en"] 55</span>
        <button class="btn btn--gold" disabled="@(!Game.CanCreateAcademyPlayer)" @onclick="Create">
            @Loc["＋ Crear jugador"]
        </button>
    </div>
    @if (!Game.CanCreateAcademyPlayer)
    {
        <div class="muted mt" style="font-size:12.5px;">@Loc["No te alcanza la plata para crear un jugador."]</div>
    }
</div>

@if (Game.State.Academy.Count == 0)
{
    <div class="empty">
        <div class="empty__ico">🎓</div>
        <p>@Loc["Todavía no creaste ningún jugador."]</p>
    </div>
}
else
{
    <div class="section-title"><span class="dot"></span> @Loc["Tus jugadores"] (@Game.State.Academy.Count)</div>
    <div class="grid grid--cards">
        @foreach (var a in Game.State.Academy.OrderByDescending(x => x.Rating))
        {
            var cost = GameService.TrainingCost(a.Rating);
            var need = GameService.XpNeeded(a.Rating);
            // El techo manda: una promesa no puede pasar de su potencial.
            var techo = Math.Min(GameService.MaxRating, a.Potential <= 0 ? 99 : a.Potential);
            var maxed = a.Rating >= techo;
            var pct = maxed ? 100 : (int)Math.Round(100.0 * a.Xp / need);
            <div class="card card--pad aca">
                <div class="row" style="justify-content:space-between; align-items:flex-start;">
                    <div class="row">
                        <div class="dot-player @Tier(a.Rating)" style="width:52px;height:52px;font-size:21px;">@a.Rating</div>
                        <div>
                            <div style="font-family:var(--font-head); font-size:17px;">@a.Name</div>
                            <div class="muted" style="font-size:12.5px;">@a.Pos.Full() · @a.Nation</div>
                        </div>
                    </div>
                    <div style="text-align:right;">
                        <span class="pill pill--gold">@Loc[GameService.AcademyTier(a.Rating)]</span>
                        @if (techo < 99)
                        {
                            <div class="faint" style="font-size:11px; margin-top:4px;">@Loc["Techo"] @techo</div>
                        }
                    </div>
                </div>

                <div class="aca__bar mt" title="@a.Xp / @need">
                    <span style="width:@(pct)%"></span>
                </div>
                <div class="row" style="justify-content:space-between; font-size:12px; color:var(--ink-faint); margin-top:5px;">
                    <span>@(maxed ? Loc["Máximo"] : $"{a.Xp} / {need} XP")</span>
                    <span>@a.Sessions @Loc["entrenos"] · @a.Matches @Loc["Partidos"]</span>
                </div>

                <div class="row wrap mt" style="gap:8px;">
                    <button class="btn btn--gold" style="flex:1; padding:10px;"
                            disabled="@(maxed || Game.State.Money < cost)"
                            @onclick="() => Game.TrainAcademyPlayer(a.Id)">
                        @(maxed ? Loc["Máximo"] : $"🏋 {Loc["Entrenar"]} · ${cost}M")
                    </button>
                    <button class="btn btn--ghost" style="padding:10px 14px;" @onclick="() => Game.SellAcademyPlayer(a.Id)">
                        @Loc["Vender"]
                    </button>
                </div>
            </div>
        }
    </div>

    <div class="section-title"><span class="dot"></span> @Loc["Ruta de avances"]</div>
    <div class="card card--pad">
        <div class="row wrap" style="gap:8px;">
            @foreach (var (tier, from) in Route)
            {
                var reached = Game.State.Academy.Any(a => a.Rating >= from);
                <span class="pill @(reached ? "pill--green" : "")" style="padding:8px 12px;">
                    @(reached ? "✓" : "•") @Loc[tier] <span class="muted">@from+</span>
                </span>
            }
        </div>
    </div>
}
}

@code {
    private string Tab = "cantera";
    private string _name = "", _nation = "";
    private Position _pos = Position.FWD;

    // ---- Copa juvenil ----
    private readonly List<string> Elegidos = new();

    private void Toggle(string id)
    {
        if (!Elegidos.Remove(id) && Elegidos.Count < GameService.YouthSquadSize)
            Elegidos.Add(id);
    }

    private void Jugar(GameService.YouthCup cup) => Game.PlayYouthCup(cup, Elegidos.ToList());

    private static readonly (string tier, int from)[] Route =
    {
        ("Juvenil", 55), ("Promesa", 60), ("Titular", 70), ("Figura", 80), ("Crack", 88), ("Leyenda", 94),
    };

    private void Create()
    {
        if (Game.CreateAcademyPlayer(_name, _pos, _nation) is not null)
        {
            _name = ""; _nation = "";
        }
    }

    private static string Tier(int rating) => rating >= 85 ? "" : rating >= 75 ? "silver" : "bronze";
}
